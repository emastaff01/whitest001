# =============================================================
# .env.example （環境変数のテンプレート / 見本）
# -------------------------------------------------------------
# このファイルは「どんな環境変数が必要か」を示す見本です。
# 実際の値は書きません。安全のため Git にコミットしてOKです。
#
# 使い方:
#   1. このファイルをコピーして「.env」という名前にする
#   2. .env の方に実際の値を入れる
#   3. .env は .gitignore 済みなのでコミットされない（秘密が漏れない）
#
# Astro では PUBLIC_ で始まる変数だけがブラウザ側（クライアント）に
# 公開されます。秘密にしたい鍵は PUBLIC_ を付けないこと。
# =============================================================

# --- サイトの公開URL（origin だけ。末尾スラッシュなし）---
# OGP・canonical・構造化データの絶対URL生成に使う「ホスト部分」。
# サブディレクトリ(/test-whi)は含めない（base 側＝PUBLIC_BASE_PATH で管理）。
# 本番公開時は https://whitehouse-imari.net に差し替える。
PUBLIC_SITE_URL=https://test001-665477084949.asia-northeast1.run.app/

# --- サイトを置くサブディレクトリ（base）---
# テスト段階は /test-whi。本番（ルート直下）公開時は / に変える。
# astro.config.mjs がこの値を読んで site/base に反映する。
PUBLIC_BASE_PATH=

# --- GA4 計測ID（本番接続は後フェーズ。今は空でよい）---
# 本番化フェーズで上司/クライアントから受け取った測定ID（G-XXXXXXX）を入れる。
PUBLIC_GA4_ID=

# =============================================================
# 以下は「本番化フェーズ」で使う予定の項目（テスト段階では未使用）。
# 担当者が Firebase プロジェクトに招待され、権限が入ってから設定する。
# 今は中身を空のままにしておく。
# =============================================================

# --- Firebase（クライアント側で使う公開設定。後フェーズで設定）---
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# --- メール送信（Cloudflare Worker + Resend。後フェーズで設定）---
# Resend の API キーは「秘密情報」。PUBLIC_ を付けず、サーバー側でのみ使用する。
RESEND_API_KEY=
