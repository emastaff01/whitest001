---
// =============================================================
// src/pages/plan/[id].astro （結婚式プラン詳細ページ）
// -------------------------------------------------------------
// URL: /test-whi/plan/[id]/
// ・Astroの動的ルート。getStaticPaths() で全プランのIDから静的生成。
// ・フェア詳細と同じ骨組みだが、プランには「開催日程・空き状況」が無いため、
//   日程選択UIの代わりに「価格・含まれるもの・対象スタイル・相談CTA」を置く。
// ・Schema.org Product(+Offer) の JSON-LD で構造化データを出力（SEO対応）。
// =============================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaButton from '../../components/common/CtaButton.astro';
import { getPlans } from '../../lib/getPlans';
import { getSiteSettings } from '../../lib/getSiteSettings';
import { url } from '../../lib/url';
import { getTaxonomyMap } from '../../lib/getTaxonomies';
import type { Plan } from '../../types';

// ---- 動的ルートのパス生成 ----
// この関数で「どのURLを静的生成するか」を Astro に伝える。
// 公開中の全プランIDを返すことで、/plan/private-full/ などが自動生成される。
export async function getStaticPaths() {
  const plans = getPlans();
  return plans.map((plan) => ({
    params: { id: plan.id },
    props: { plan },
  }));
}

interface Props {
  plan: Plan;
}
const { plan } = Astro.props;
const settings = getSiteSettings();

// 画像パス（base 付き）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const heroJpg = `${base}${plan.thumbnail.src}`;
const heroWebp = heroJpg.replace(/\.jpg$/, '.webp');

// 価格を3桁区切りに整形（日本式）。priceTo があれば「〜上限」も作る。
const priceFromText = plan.priceFrom.toLocaleString('ja-JP');
const priceToText = plan.priceTo ? plan.priceTo.toLocaleString('ja-JP') : null;

// プランに含まれるもの：includeIds（id参照）を表示用ラベルへ変換する。
// 早見表に無い id（引退・削除済み）は undefined になるので filter で除外（防御）。
// 「label is string」は型ガード。これで includeLabels が string[] に確定し、check を通る。
const includeMap = getTaxonomyMap('plan-includes');
const includeLabels = (plan.includeIds ?? [])
  .map((id) => includeMap.get(id)?.label)
  .filter((label): label is string => Boolean(label));

// 対象スタイル：tagIds（id参照）を表示用ラベルへ変換する（含まれるものと同じ流儀）。
// 旧 STYLE_LABELS のハードコードを廃止し、マスター(plan-tags)参照へ一本化。
const tagMap = getTaxonomyMap('plan-tags');
const tagLabels = (plan.tagIds ?? [])
  .map((id) => tagMap.get(id)?.label)
  .filter((label): label is string => Boolean(label));
  
// 相談・見積りフォームへのリンク。フォーム実装時に plan_id で照合できるよう
// クエリで渡す（フェアが ?fair_id= を渡しているのと同じ考え方）。
const contactUrl =
`${url("/contact-plan/")}?plan_id=${encodeURIComponent(plan.id)}`;

// 公開URL（JSON-LD用の絶対URL）
const SITE_URL =
  import.meta.env.PUBLIC_SITE_URL ??
  'https://ema-run-665477084949.asia-northeast1.run.app/test-whi';
const absoluteImageUrl = new URL(heroJpg, SITE_URL).href;

// Schema.org Product: プランを「商品」として構造化データ化（価格付き）。
// priceTo があれば価格帯(AggregateOffer)、無ければ単価(Offer)として出す。
const offer = priceToText
  ? {
      '@type': 'AggregateOffer',
      priceCurrency: 'JPY',
      lowPrice: plan.priceFrom,
      highPrice: plan.priceTo,
      availability: 'https://schema.org/InStock',
    }
  : {
      '@type': 'Offer',
      priceCurrency: 'JPY',
      price: plan.priceFrom,
      availability: 'https://schema.org/InStock',
    };

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: plan.title,
  description: plan.description,
  image: absoluteImageUrl,
  brand: {
    '@type': 'Organization',
    name: settings.siteName,
  },
  offers: offer,
};
---

<BaseLayout
  title={`${plan.title}｜ホワイトハウス伊万里`}
  description={plan.description}
  ogImage={plan.thumbnail.src}
>
  {/* 構造化データ（Product + Offer） */}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />

  <article class="plan-detail">
    {/* ヒーロー画像 */}
    <div class="plan-detail__hero">
      <picture>
        <source type="image/webp" srcset={heroWebp} />
        <img
          src={heroJpg}
          alt={plan.thumbnail.alt}
          width="1200"
          height="800"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </picture>
    </div>

    <div class="plan-detail__inner">
      {/* タイトル＆説明 */}
      <header class="plan-detail__header">
        <p class="plan-detail__overline">PLAN</p>
        <h1 class="plan-detail__title">{plan.title}</h1>
        <p class="plan-detail__lead">{plan.description}</p>
      </header>

      {/* 価格 */}
      <section class="plan-detail__price-box">
        <p class="plan-detail__price-label">プラン総額（目安）</p>
        <p class="plan-detail__price">
          <span class="plan-detail__price-num">{priceFromText}</span>
          <span class="plan-detail__price-suffix">円</span>
          {
            priceToText ? (
              <>
                <span class="plan-detail__price-tilde">〜</span>
                <span class="plan-detail__price-num">{priceToText}</span>
                <span class="plan-detail__price-suffix">円</span>
              </>
            ) : (
              <span class="plan-detail__price-suffix">〜</span>
            )
          }
        </p>
        {
          plan.guestCountBase && (
            <p class="plan-detail__price-note">
              {plan.guestCountBase}名様でのご利用を基準とした目安金額です。
              人数・内容により変動します。
            </p>
          )
        }
      </section>

      {/* 含まれるもの：includeIds をラベル化して表示（該当があるときだけ） */}
      {
        includeLabels.length > 0 && (
          <section class="plan-detail__block">
            <p class="plan-detail__block-label">プランに含まれるもの</p>
            <ul class="plan-detail__includes">
              {includeLabels.map((label) => (
                <li>{label}</li>
              ))}
            </ul>
          </section>
        )
      }

     {/* 対象スタイル：tagLabels がある時だけ表示。
          スタイル詳細ページは停止のため、リンクではなくタグ（span）表示。
          ラベルはマスター(plan-tags)由来。未知 id は tagLabels の段階で除外済み。 */}
      {
        tagLabels.length > 0 && (
          <section class="plan-detail__block">
            <p class="plan-detail__block-label">対象のウェディングスタイル</p>
            <ul class="plan-detail__styles" role="list">
              {tagLabels.map((label) => (
                <li>
                  <span class="plan-detail__style-tag">{label}</span>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      {/* 相談・お見積りCTA */}
      <section class="plan-detail__cta">
        <CtaButton href={contactUrl} variant="solid" ga="planCV">
          このプランで相談・お見積りに進む
        </CtaButton>
        <p class="plan-detail__cta-note">
          内容のカスタマイズも承ります。まずはお気軽にご相談ください。
        </p>
      </section>

      {/* 一覧に戻る */}
      <p class="plan-detail__back">
        <a href={url('/plan/')}>←  プラン一覧に戻る</a>
      </p>
    </div>
  </article>
</BaseLayout>

<style>
  .plan-detail {
    background-color: var(--white);
  }
  .plan-detail__hero {
    max-width: var(--maxw-content);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
    padding-top: clamp(40px, 5vw, 64px);
  }
  .plan-detail__hero img {
    display: block;
    width: 100%;
    height: auto;
  }
  .plan-detail__inner {
    max-width: var(--maxw-narrow);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
    padding-block: clamp(48px, 6vw, 80px);
  }
  .plan-detail__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .plan-detail__overline {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--green);
    margin-bottom: 24px;
  }
  .plan-detail__title {
    font-family: var(--font-jp-serif);
    font-weight: var(--weight-light);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    line-height: 1.5;
    color: var(--charcoal);
    margin-bottom: 20px;
  }
  .plan-detail__lead {
    font-family: var(--font-jp-sans);
    font-size: clamp(0.92rem, 1.6vw, 1rem);
    line-height: var(--lh-body);
    color: var(--dark-gray);
  }

  /* 価格ボックス */
  .plan-detail__price-box {
    text-align: center;
    border-top: 0.5px solid var(--hairline-dark);
    border-bottom: 0.5px solid var(--hairline-dark);
    padding-block: 32px;
    margin-bottom: 48px;
  }
  .plan-detail__price-label {
    font-family: var(--font-jp-sans);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--gray);
    margin-bottom: 14px;
  }
  .plan-detail__price {
    color: var(--charcoal);
    line-height: 1.1;
  }
  .plan-detail__price-num {
    font-family: var(--font-en-display);
    font-weight: var(--weight-regular);
    font-size: clamp(2rem, 5vw, 2.8rem);
    letter-spacing: 0.02em;
  }
  .plan-detail__price-suffix {
    font-family: var(--font-jp-sans);
    font-size: 1rem;
    color: var(--dark-gray);
    margin-left: 4px;
  }
  .plan-detail__price-tilde {
    font-family: var(--font-jp-sans);
    font-size: 1.2rem;
    color: var(--dark-gray);
    margin-inline: 8px;
  }
  .plan-detail__price-note {
    margin-top: 16px;
    font-family: var(--font-jp-sans);
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--gray);
  }

  /* 共通ブロック（含まれるもの・対象スタイル） */
  .plan-detail__block {
    margin-bottom: 48px;
  }
  .plan-detail__block-label {
    font-family: var(--font-jp-sans);
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--green);
    margin-bottom: 20px;
  }

  /* 含まれるもの（・付きリスト） */
  .plan-detail__includes {
    font-family: var(--font-jp-sans);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--dark-gray);
  }
  .plan-detail__includes li {
    padding-left: 1.2em;
    position: relative;
  }
  .plan-detail__includes li::before {
    content: '・';
    color: var(--green);
    position: absolute;
    left: 0;
  }

  /* 対象スタイル（タグ風リンク） */
  .plan-detail__styles {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .plan-detail__style-tag {
    display: inline-block;
    font-family: var(--font-jp-sans);
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--green);
    border: 0.5px solid var(--hairline-green);
    padding: 6px 16px;
  }

  /* CTA */
  .plan-detail__cta {
    margin-top: 56px;
    text-align: center;
  }
  .plan-detail__cta-note {
    margin-top: 14px;
    font-family: var(--font-jp-sans);
    font-size: 0.8rem;
    color: var(--gray);
  }

  /* 一覧に戻る */
  .plan-detail__back {
    margin-top: 64px;
    text-align: center;
  }
  .plan-detail__back a {
    font-family: var(--font-jp-sans);
    font-size: 0.88rem;
    color: var(--green);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .plan-detail__back a:hover {
    color: var(--charcoal);
    border-bottom-color: var(--charcoal);
  }
</style>
