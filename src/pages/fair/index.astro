// =============================================================
// src/pages/fair/index.astro （ブライダルフェア一覧ページ）
// -------------------------------------------------------------
// URL: /test-whi/fair/
// ・公開中の全フェアを FairCard で一覧表示。
// ・開催日をカレンダーで複数選択（OR）、フェア内容をタグで複数選択（AND）して
//   ページ内（クライアントサイド）で絞り込む。選んだ瞬間に即反映。
// ・最終CTAセクションも置いてCV導線を確保。
// =============================================================

import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/common/PageHeader.astro';
import FairCard from '../../components/fair/FairCard.astro';
import CtaSection from '../../components/common/CtaSection.astro';
import { getFairs } from '../../lib/getFairs';
// 同日ブロックのリンク生成に使う（内部リンクは必ず url() を通す）。Fair 型も使う（案C用）。
import type { Fair } from '../../types';
// タグ絞り込み用に fair-tags のマスターを取得する（id -> タグ情報 の Map）。
import { getTaxonomyMap } from '../../lib/getTaxonomies';
// 祝日CSVを読むために使う。fs=ファイル読み込み、path=パス組み立て。
// どちらもNode標準の機能で、ビルド時のfrontmatterでのみ動く（クライアント側では使えない）。
import fs from 'node:fs';
import path from 'node:path';

const fairs = getFairs();

// 公開中の fair-tags を sortOrder 昇順で。sortOrder 未設定は 0 として扱う。
const fairTagList = [...getTaxonomyMap('fair-tags').values()]
  .filter((t) => t.isPublished)
  .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));

// 満席（×）を表す status。status は available / few / full の3値で full が満席。
// 空き判定は「full 以外なら空きあり」。「: string」注釈は「一致し得ない比較」の型エラー回避のため必須（外さない）。
const FULL_STATUS: string = 'full';

// 今日（JST）を 'YYYY-MM-DD' で作る。過去日除外やカレンダーの開始月に使う。
// new Date をそのまま整形すると UTC 解釈で前日にズレ得るため、+9時間して UTC ゲッターで読む（§7の流儀）。
const jstNow = new Date(Date.now() + 9 * 60 * 60 * 1000);
const y = jstNow.getUTCFullYear();
const m = String(jstNow.getUTCMonth() + 1).padStart(2, '0');
const d = String(jstNow.getUTCDate()).padStart(2, '0');
const todayJst = `${y}-${m}-${d}`;

// 日付を必ず 'YYYY-MM-DD'（ゼロ埋め）にそろえるヘルパー。
// フェアのデータには 2026-9-22 のようにゼロ埋めされていない日付が混じっており、
// そのままだと「文字列比較」「並び替え」「カレンダーとの突き合わせ」がすべてズレる。
// 例：'2026-9-22'.slice(5,7) は '9-' → Number('9-') が NaN → 月が計算できずカレンダーが空になる。
const padDate = (dateStr: string): string => {
  const parts = dateStr.split('-'); // ['2026', '9', '22'] のように分解
  const yy = parts[0];
  const mm = parts[1];
  const dd = parts[2];
  // 想定外の形式（分解できない等）はそのまま返して壊さない
  if (yy === undefined || mm === undefined || dd === undefined) return dateStr;
  // 月・日を2桁にゼロ埋めして 'YYYY-MM-DD' に組み直す
  return `${yy}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`;
};

// 一覧に出すフェアを、空き状況をもとに作り直す。
// ・各フェアについて「空席のある日程（今日以降・full 以外が1つでもある日）」だけを日付の早い順に取り出す
// ・空席のある日程が1つも無い（＝全日程満席）フェアは一覧から除外する
const visibleFairs = fairs
  .map((fair) => {
    const availableSchedule = (fair.schedule ?? [])
      .filter(
        (day) =>
          // 比較は必ずゼロ埋めどうしで行う（padDate を通さないと 9月が10月より後ろに並ぶ等のズレが出る）
          padDate(day.date) >= todayJst && // 今日以降の日程だけ（過去日を除外）
          day.times.some((slot) => slot.status !== FULL_STATUS), // 空席が1つでもある
      )
      // 日付をゼロ埋め形式にそろえる。これで以降の並び替え・カレンダー突き合わせがすべて正しく動く
      .map((day) => ({ ...day, date: padDate(day.date) }))
      // ゼロ埋め済みなので、文字列比較がそのまま日付の早い順になる（§7の流儀）
      .sort((a, b) => a.date.localeCompare(b.date));
    return { fair, availableSchedule };
  })
  // 空席のある日程が0件のフェア（＝全日程満席）を外す
  .filter((entry) => entry.availableSchedule.length > 0);

// ===== ここからカレンダー用のデータ作り =====

// 内閣府の祝日CSV（public/data/holiday/ に置く）を読み、'YYYY-MM-DD' の集合を作る。
// ビルド時に1回だけ実行される（新しいCSVに差し替えて再ビルドすれば祝日が更新される）。
const loadHolidaySet = (): Set<string> => {
  const set = new Set<string>();
  // CSVの置き場所。process.cwd() は「ビルドを実行したプロジェクトルート」を指す。
  const csvPath = path.join(process.cwd(), 'public', 'data', 'holiday', 'syukujitsu.csv');
  try {
    // CSVはShift-JISだが、必要なのは日付（半角数字と区切り）だけ。
    // latin1（1バイト=1文字）で読めば、日本語部分が別文字になっても日付の抽出には影響しない。
    const text = fs.readFileSync(csvPath, 'latin1');
    // 'YYYY/M/D' 形式の日付をすべて拾う。区切りは / と - の両方、ゼロ埋め有無も許容。
    for (const mt of text.matchAll(/(\d{4})[/-](\d{1,2})[/-](\d{1,2})/g)) {
      const yy = mt[1];
      const mm = mt[2];
      const dd = mt[3];
      // 正規表現がマッチした時点で3つとも存在するが、型の厳格設定でも安全に通すためガードする
      if (yy === undefined || mm === undefined || dd === undefined) continue;
      // 'YYYY-MM-DD' に整える（7 -> 07 とゼロ埋めしてカレンダーの date と桁をそろえる）
      set.add(`${yy}-${mm.padStart(2, '0')}-${dd.padStart(2, '0')}`);
    }
  } catch {
    // CSVが無い・読めない場合でも、祝日の色付けが消えるだけでビルドは止めない（安全側の設計）。
    console.warn('[fair] 祝日CSVを読み込めませんでした:', csvPath);
  }
  return set;
};
// ビルド時に1回だけCSVを読み、祝日集合を作る。
const holidaySet = loadHolidaySet();

// 空席のあるフェアが「1日でもある日」を集めた集合。
// カレンダーで ○（押せる日）にするかどうかの判定に使う。
const availableDateSet = new Set<string>(
  visibleFairs.flatMap((entry) => entry.availableSchedule.map((day) => day.date)),
);

// 日付（'YYYY-MM-DD'）から曜日番号（0=日 … 6=土）を求めるヘルパー。
// new Date を直接使うとJSTで曜日が1日ズレ得るため、Date.UTC + getUTCDay で求める（§7の流儀）。
const weekdayOf = (dateStr: string): number => {
  const parts = dateStr.split('-'); // ['2026', '07', '22']
  const yy = Number(parts[0]);
  const mm = Number(parts[1]);
  const dd = Number(parts[2]);
  return new Date(Date.UTC(yy, mm - 1, dd)).getUTCDay();
};

// 空席のある日の「曜日」を集めた集合（0=日 … 6=土）。
// 曜日チップを「押せる／押せない」に出し分けるために使う（空席が1日も無い曜日はグレーアウト）。
const availableWeekdaySet = new Set<number>(
  [...availableDateSet].map((date) => weekdayOf(date)),
);

// 曜日チップの定義。表示順はカレンダーに合わせて月曜始まり。
// num は getUTCDay の値（0=日 … 6=土）。data属性やJSの照合はこの数値で行う。
const weekdayChips = [
  { num: 1, label: '月' },
  { num: 2, label: '火' },
  { num: 3, label: '水' },
  { num: 4, label: '木' },
  { num: 5, label: '金' },
  { num: 6, label: '土' },
  { num: 0, label: '日' },
];

// カレンダーに出す月の範囲を決める。
// 開始：今日の月。終了：空席のある最終日の月（空席日が無ければ今日の月だけ）。
const sortedAvailable = [...availableDateSet].sort((a, b) => a.localeCompare(b));
const lastAvailable =
  sortedAvailable.length > 0 ? sortedAvailable[sortedAvailable.length - 1] : todayJst;

const startYear = Number(todayJst.slice(0, 4));
const startMonth = Number(todayJst.slice(5, 7)); // 1〜12
const endYear = Number(lastAvailable.slice(0, 4));
const endMonth = Number(lastAvailable.slice(5, 7));

// カレンダー1マス分のデータ。
type CalDay = {
  date: string; // 'YYYY-MM-DD'（月外の空マスは空文字）
  dayNum: number; // 日にち（空マスは0）
  isAvailable: boolean; // 空席のあるフェアがある＝○（押せる）
  isSat: boolean; // 土曜（青系）
  isSunHoliday: boolean; // 日曜または祝日（赤系）
};
// カレンダー1か月分のデータ。
type CalMonth = {
  year: number;
  month: number; // 1〜12
  label: string; // '7月'
  days: CalDay[]; // 月曜始まりで、7の倍数に揃えた全マス（先頭・末尾は空マスで埋める）
};

// 空マス（月の外側）を作る小さなヘルパー。
const emptyCell = (): CalDay => ({
  date: '',
  dayNum: 0,
  isAvailable: false,
  isSat: false,
  isSunHoliday: false,
});

// 指定した年月のカレンダー（月曜始まり）を組み立てる。
const buildMonth = (year: number, month: number): CalMonth => {
  // その月の1日の曜日（0=日 … 6=土）。Date.UTC で作り UTC ゲッターで読む＝タイムゾーンでズレない。
  const firstWeekday = new Date(Date.UTC(year, month - 1, 1)).getUTCDay();
  // その月の日数（翌月の0日目＝当月末日、というテクで求める）。
  const daysInMonth = new Date(Date.UTC(year, month, 0)).getUTCDate();
  // 月曜始まりにしたときの、先頭に入れる空マスの数。
  // 例：1日が水曜（getUTCDay=3）なら (3+6)%7=2 → 月・火の2マスを空ける。
  const leadingBlanks = (firstWeekday + 6) % 7;

  const cells: CalDay[] = [];
  // 先頭の空マス
  for (let i = 0; i < leadingBlanks; i += 1) cells.push(emptyCell());
  // 日にちのマス
  for (let dd = 1; dd <= daysInMonth; dd += 1) {
    const mm = String(month).padStart(2, '0');
    const ds = String(dd).padStart(2, '0');
    const date = `${year}-${mm}-${ds}`;
    const weekday = new Date(Date.UTC(year, month - 1, dd)).getUTCDay();
    cells.push({
      date,
      dayNum: dd,
      // 空席日の集合に含まれるかで判定。過去日は集合に無いので自然に押せない扱いになる。
      isAvailable: availableDateSet.has(date),
      isSat: weekday === 6,
      isSunHoliday: weekday === 0 || holidaySet.has(date),
    });
  }
  // 末尾の空マス（全体を7の倍数に揃える）
  while (cells.length % 7 !== 0) cells.push(emptyCell());

  return { year, month, label: `${month}月`, days: cells };
};

// 開始月から終了月まで、1か月ずつ進めながら配列に詰める。
const calendarMonths: CalMonth[] = [];
let iterYear = startYear;
let iterMonth = startMonth;
while (iterYear < endYear || (iterYear === endYear && iterMonth <= endMonth)) {
  calendarMonths.push(buildMonth(iterYear, iterMonth));
  iterMonth += 1;
  if (iterMonth > 12) {
    iterMonth = 1;
    iterYear += 1;
  }
}

// ===== 案X：同一日開催フェアのまとめ（日付ごと・折りたたみ）用データ =====
// 曜日番号(0=日 … 6=土) -> 日本語表記。日付レールの「金」等に使う。
const WEEKDAY_LABELS_JA = ['日', '月', '火', '水', '木', '金', '土'];

// 「日付 -> その日開催のフェア」を集める用のペア型。
// FairCard には『その日1日だけの schedule』を渡したいので、フェア本体(fair)と その日の日程(day)を対で持つ。
// NonNullable<...> は「schedule が optional(undefined あり得る)でも要素型を安全に取り出す」ための書き方。
type SameDayEntry = { fair: Fair; day: NonNullable<Fair['schedule']>[number] };

// 日付ごとに、その日開催のフェア(と日程)を集める。
// visibleFairs は { fair, availableSchedule }。availableSchedule は「空席あり・今日以降」の日程だけ。
const fairsByDate = new Map<string, SameDayEntry[]>();
for (const { fair, availableSchedule } of visibleFairs) {
  for (const day of availableSchedule) {
    // その日付のリストが無ければ空配列を用意してから push する
    const list = fairsByDate.get(day.date) ?? [];
    list.push({ fair, day });
    fairsByDate.set(day.date, list);
  }
}

// Map を「日付の早い順」に並べ、各日付ブロックのデータに変換する。
const sameDayBlocks = [...fairsByDate.entries()]
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([date, entriesOnDay], dateIndex) => {
    // 各日付で先頭に出す「代表フェア」を、日付の並び順に応じてずらす（＝回転）。
    // これをしないと毎日同じフェアが先頭に来て「フェアは1種類だけ」と誤解される。
    // 日付の通し番号(dateIndex)を、その日のフェア件数で割った余りを代表の位置にする。
    // 例：その日のフェアが[A,B,C]なら 0日目→A / 1日目→B / 2日目→C / 3日目→A … と循環する。
    const count = entriesOnDay.length;
    const featuredIndex = count > 0 ? dateIndex % count : 0;
    const featured = entriesOnDay[featuredIndex];
    // 代表を除いた残り（元の順番は維持）。これが折りたたみ側に入る。
    const rest = entriesOnDay.filter((_, idx) => idx !== featuredIndex);
    // 代表を先頭に並べ替え。featured が万一 undefined でも型を保てるよう分岐する。
    const ordered = featured ? [featured, ...rest] : rest;
    return {
    date, // 'YYYY-MM-DD'
    weekdayLabel: WEEKDAY_LABELS_JA[weekdayOf(date)], // '金' など
    weekdayNum: weekdayOf(date), // 0=日 … 6=土。B側の曜日絞り込み（ブロックごと出し隠し）に使う
    isHoliday: holidaySet.has(date), // この日が祝日か（レールの色分け・祝日→赤に使う）
      // FairCard 用：schedule をその日1日だけに差し替えたフェアの配列。
      // これで FairCard が表示する代表日が、このブロックの日付にちょうど一致する
      // （他日程が混じって「一番早い別の日」が表示される事故を防ぐ）。
      cards: ordered.map(({ fair, day }) => ({ ...fair, schedule: [day] })),
    };
  });
---

<BaseLayout
  title="ブライダルフェア一覧｜ホワイトハウス伊万里"
  description="ホワイトハウス伊万里で開催中のブライダルフェア一覧。模擬挙式・無料試食・館内見学・相談会など、用途にあわせてお選びいただけます。"
>
  <PageHeader
    overline="FAIR"
    title="ブライダルフェアを探す"
    description="見学・試食・相談ができるフェアを開催中です。お気軽にお申し込みください。"
  />

<section class="fair-list">
  {
    /* 絞り込み条件バー（画面ヘッダーの下に追従・全幅）。
       選んだ内容を名前で表示し、件数と解除ボタンも置く。
       フェアが1件以上あるときだけ出す。 */
    visibleFairs.length > 0 && (
      <div class="fair-stickybar" data-fair-stickybar>
        <div class="fair-stickybar__inner">
          <div class="fair-stickybar__summary">
            <p>開催日：<span data-summary-dates>すべて</span></p>
            <p>曜日：<span data-summary-weekdays>すべて</span></p>
            <p>フェア内容：<span data-summary-tags>すべて</span></p>
          </div>
          <div class="fair-stickybar__actions">
            <p class="fair-stickybar__count">
              <span data-fair-count>{visibleFairs.length}</span>件のフェアが該当
            </p>
            <button type="button" class="fair-stickybar__clear" data-fair-clear>
              条件を解除する
            </button>
          </div>
        </div>
      </div>
    )
  }
  
  <div class="fair-list__inner">
    {
      /* 表示対象のフェアがある時だけフィルタUIを出す */
      visibleFairs.length > 0 && (
          <div class="fair-filter" data-fair-filter>
            <div class="fair-filter__cols">
              {/* 左カラム：開催日のカレンダー */}
              <div class="fair-filter__col">
                <p class="fair-filter__heading">開催日を選択（複数可）</p>
                
                <div class="fair-cal" data-fair-cal>
                  {calendarMonths.map((month, index) => (
                    <div class="fair-cal__month" data-month-index={index} hidden={index !== 0}>
                      {/* 見出し＋前月・次月の切り替え */}
                      <div class="fair-cal__nav">
                        {index > 0 ? (
                          <button
                            type="button"
                            class="fair-cal__navbtn fair-cal__navbtn--prev"
                            data-goto={index - 1}
                          >
                            {`◀ ${calendarMonths[index - 1].label}`}
                          </button>
                        ) : (
                          <span class="fair-cal__navbtn" aria-hidden="true" />
                        )}

                        <span class="fair-cal__title">{month.label}</span>

                        {index < calendarMonths.length - 1 ? (
                          <button
                            type="button"
                            class="fair-cal__navbtn fair-cal__navbtn--next"
                            data-goto={index + 1}
                          >
                            {`${calendarMonths[index + 1].label} ▶`}
                          </button>
                        ) : (
                          <span class="fair-cal__navbtn" aria-hidden="true" />
                        )}
                      </div>

                      {/* 曜日の見出し（月曜始まり） */}
                      <div class="fair-cal__weekhead">
                        <span>月</span>
                        <span>火</span>
                        <span>水</span>
                        <span>木</span>
                        <span>金</span>
                        <span class="is-sat">土</span>
                        <span class="is-sun">日</span>
                      </div>

                      {/* 日にちのマス。空マスは span、押せる日/押せない日は button で出す */}
                      <div class="fair-cal__grid">
                        {month.days.map((cell) =>
                          cell.date === '' ? (
                            <span class="fair-cal__cell fair-cal__cell--empty" aria-hidden="true" />
                          ) : (
                            <button
                              type="button"
                              class:list={[
                                'fair-cal__cell',
                                { 'is-sat': cell.isSat },
                                { 'is-sun': cell.isSunHoliday },
                                { 'is-available': cell.isAvailable },
                              ]}
                              data-date={cell.date}
                              disabled={!cell.isAvailable}
                            >
                              <span class="fair-cal__daynum">{cell.dayNum}</span>
                              <span class="fair-cal__mark">{cell.isAvailable ? '○' : '×'}</span>
                            </button>
                          ),
                        )}
                      </div>
                    </div>
                  ))}
                    </div>
                  
                    {/* 曜日で絞り込む（複数可・選んだ曜日のいずれかに空席があれば表示） */}
                    <div class="fair-filter__weekdays">
                      <p class="fair-filter__heading">曜日で絞り込む（複数可）</p>
                      <div class="fair-filter__tags">
                        {weekdayChips.map((wd) => (
                          <label
                            class:list={[
                              'fair-filter__chip',
                              { 'is-disabled': !availableWeekdaySet.has(wd.num) },
                            ]}
                          >
                            <input
                              type="checkbox"
                              class="fair-filter__checkbox fair-filter__weekday-checkbox"
                              value={wd.num}
                              disabled={!availableWeekdaySet.has(wd.num)}
                            />
                            <span>{wd.label}</span>
                          </label>
                        ))}
                      </div>
                        </div>
                      
                        {/* 日付選択中だけ表示する注意書き。普段は非表示にしておき、曜日セクションに is-locked が付いたら CSS で表示する */}
                        <p class="fair-filter__weekdays-note">日付を選択中は曜日で絞り込めません</p>
                      </div>
                  
                  {/* 右カラム：フェア内容のタグ */}
              {fairTagList.length > 0 && (
                <div class="fair-filter__col">
                  <p class="fair-filter__heading">フェア内容を選択（複数可）</p>
                  <div class="fair-filter__tags">
                    {fairTagList.map((tag) => (
                      <label class="fair-filter__chip">
                        <input type="checkbox" class="fair-filter__checkbox" value={tag.id} />
                        <span>{tag.label}</span>
                      </label>
                    ))}
                  </div>
                </div>
                        )}
                      </div>
                    </div>
                  )
                }

      {
        visibleFairs.length === 0 ? (
          <p class="fair-list__empty">現在開催予定のフェアはありません。</p>
        ) : (
        <Fragment>
          {/* 案X：同一日開催フェアのまとめ（日付ごと・折りたたみ）。既定は非表示、日付選択時にJSで表示する */}
          <div class="fair-sameday" data-fair-sameday>
            {sameDayBlocks.map((block) => (
              <div
                class="fair-sameday__block"
                data-sameday-date={block.date}
                data-weekday={block.weekdayNum}
              >
                {/* 左：日付レール。土=青・日=赤はカレンダーと同じ色分け（曜日名でクラスを付ける） */}
                <div
                  class:list={[
                    'fair-sameday__rail',
                    // 祝日は日曜と同じ赤にしたいので is-sun を優先。土曜は青。
                    { 'is-sun': block.weekdayLabel === '日' || block.isHoliday },
                    { 'is-sat': block.weekdayLabel === '土' && !block.isHoliday },
                  ]}
                >
                  <span class="fair-sameday__railmd">
                    <span class="fair-sameday__railyear">{block.date.slice(0, 4)}</span>{block.date.slice(5, 7)}<span class="fair-sameday__railslash">.</span>{block.date.slice(8, 10)}
                  </span>
                  <span class="fair-sameday__railwd">({block.weekdayLabel})</span>
                </div>
          
                {/* 右：その日のフェア。先頭(代表)は常時表示、2件目以降は折りたたみ対象 */}
                <div class="fair-sameday__content">
                  <div class="fair-sameday__cards">
                    {block.cards.map((fairForCard, idx) => (
                      <div
                        class:list={[
                          'fair-sameday__card',
                          { 'fair-sameday__card--extra': idx > 0 }, // 2件目以降は折りたたみで隠す
                        ]}
                        data-tag-ids={(fairForCard.tagIds ?? []).join(' ')}
                        data-fair-id={fairForCard.id}
                      >
                        <FairCard fair={fairForCard} holidays={holidaySet} />
                      </div>
                    ))}
                  </div>
          
                  {/* 2件以上ある日だけ「その他N件」トグルを出す（1件だけの日はボタン不要） */}
                  {block.cards.length > 1 && (
                    <button
                      type="button"
                      class="fair-sameday__toggle"
                      data-sameday-toggle
                      aria-expanded="false"
                    >
                      <span class="fair-sameday__toggle-open">その他{block.cards.length - 1}件のフェアを見る ＋</span>
                      <span class="fair-sameday__toggle-close">閉じる −</span>
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        
          <div class="fair-list__grid">
              {visibleFairs.map(({ fair, availableSchedule }) => {
                // 空席のある日程だけに差し替えたフェアを作る（元の fair は壊さない）。
                // これで FairCard が表示する代表日が「一番早い・空席あり・今日以降の日」になる。
                const fairForCard = { ...fair, schedule: availableSchedule };

                // 日付フィルタ用：このフェアの空席日一覧（半角スペース区切り）
                const openDates = availableSchedule.map((day) => day.date).join(' ');
                
                // 曜日フィルタ用：空席日を曜日番号（0=日 … 6=土）に変換し、重複を除いた一覧（半角スペース区切り）
                const openWeekdays = [
                  ...new Set(availableSchedule.map((day) => weekdayOf(day.date))),
                ].join(' ');
                
                return (
                  <div
                    class="fair-list__item"
                    data-tag-ids={(fair.tagIds ?? []).join(' ')}
                    data-open-dates={openDates}
                    data-open-weekdays={openWeekdays}
                  >
                    <FairCard fair={fairForCard} holidays={holidaySet} />
                  </div>
                );
              })}
            </div>

            {/* 絞り込み結果が0件のときだけJSが表示する。初期はhiddenで隠しておく */}
            <p class="fair-list__noresult" data-fair-noresult hidden>
              条件に合うフェアはありませんでした。
            </p>
          </Fragment>
        )
      }
    </div>
  </section>

  <CtaSection />
</BaseLayout>

