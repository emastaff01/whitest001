<script>
  // ===== フェア一覧のクライアントサイド絞り込み =====
  // ・タグ：チェックしたタグを「すべて」持つフェアだけ表示（AND）
  // ・日付：カレンダーで選んだ日の「いずれか」に空きがあれば表示（OR）
  // ・選んだ瞬間に即反映。表示/非表示は is-hidden の付け外し（DOMは消さない）。

  const filter = document.querySelector('[data-fair-filter]');
  const grid = document.querySelector('.fair-list__grid');

  // 絞り込みUIやカードが無いページ（0件など）では何もしない。
  if (filter && grid) {
    // --- 要素の取得 ---
    // タグ用チェックボックス（曜日用は別クラスなので :not で除外する）
    const checkboxes = Array.from(
      filter.querySelectorAll<HTMLInputElement>(
        '.fair-filter__checkbox:not(.fair-filter__weekday-checkbox)',
      ),
    );
    // 曜日用チェックボックス（月〜日）
    const weekdayCheckboxes = Array.from(
      filter.querySelectorAll<HTMLInputElement>('.fair-filter__weekday-checkbox'),
    );
    // 曜日セクション全体のラッパー。日付モード中にまとめてグレーアウト＋操作不可にするために使う（A案）
    const weekdaySection = filter.querySelector<HTMLElement>('.fair-filter__weekdays');
    // 解除ボタン・要約・件数は「追従バー」側（フィルタ枠の外）へ移したので document から取る
    const clearBtn = document.querySelector<HTMLButtonElement>('[data-fair-clear]');
    const items = Array.from(grid.querySelectorAll<HTMLElement>('.fair-list__item'));
    const noResult = document.querySelector<HTMLElement>('[data-fair-noresult]');
    // カレンダー関連
    const monthBlocks = Array.from(filter.querySelectorAll<HTMLElement>('.fair-cal__month'));
    // 押せる日（○）のマスだけ集める。× の日は disabled なのでそもそもクリックできない。
    const dayCells = Array.from(
      filter.querySelectorAll<HTMLButtonElement>('.fair-cal__cell.is-available'),
    );
    const navButtons = Array.from(filter.querySelectorAll<HTMLButtonElement>('[data-goto]'));

    // 追従バーの表示先（フィルタ枠の外なので document から取る）
    const summaryDates = document.querySelector<HTMLElement>('[data-summary-dates]');
    const summaryWeekdays = document.querySelector<HTMLElement>('[data-summary-weekdays]');
    const summaryTags = document.querySelector<HTMLElement>('[data-summary-tags]');
    const countEl = document.querySelector<HTMLElement>('[data-fair-count]');
    // 同日まとめブロック（案X）。ラッパー・各日付ブロック・折りたたみボタンを取得しておく。
    const samedayWrap = document.querySelector<HTMLElement>('[data-fair-sameday]');
    const samedayBlocks = Array.from(
      document.querySelectorAll<HTMLElement>('[data-sameday-date]'),
    );
    const samedayToggles = Array.from(
      document.querySelectorAll<HTMLButtonElement>('[data-sameday-toggle]'),
    );
    
    // 曜日番号（'0'〜'6'）→ 表示名（日〜土）の対応表。要約に「水, 金」のように名前で出すため。
    const WEEKDAY_LABELS: Record<string, string> = {
      '0': '日',
      '1': '月',
      '2': '火',
      '3': '水',
      '4': '木',
      '5': '金',
      '6': '土',
    };

    // 選択中の日付（複数）。重複を防ぐため Set を使う。
    const selectedDates = new Set<string>();

    // --- 表示判定 ---
    // カード1枚が表示対象か。タグはAND、日付はOR。
    const matches = (
      item: HTMLElement,
      selectedTags: string[],
      selectedWeekdays: string[],
    ) => {
      // タグ：選んだタグを「すべて」持つフェアだけ（AND）
      const own = new Set((item.dataset.tagIds || '').split(' ').filter(Boolean));
      const tagOk = selectedTags.every((id) => own.has(id));
    
      // 日付：選んだ日の「いずれか」に空席があれば通過（OR）。未選択なら常に通過。
      const openDates = (item.dataset.openDates || '').split(' ').filter(Boolean);
      const dateOk =
        selectedDates.size === 0 || openDates.some((date) => selectedDates.has(date));
    
      // 曜日：選んだ曜日の「いずれか」に空席があれば通過（OR）。未選択なら常に通過。
      // data-open-weekdays も value も文字列の数字（'0'〜'6'）なのでそのまま比較できる。
      const openWeekdays = (item.dataset.openWeekdays || '').split(' ').filter(Boolean);
      const weekdayOk =
        selectedWeekdays.length === 0 ||
        openWeekdays.some((wd) => selectedWeekdays.includes(wd));
    
      // タグ・日付・曜日をすべて満たすものだけ表示（軸どうしはAND）
      return tagOk && dateOk && weekdayOk;
    };

    // --- 現在の選択状態で表示を更新 ---
    const apply = () => {
      // ▼A案：日付を選んでいる間は「曜日での絞り込み」を無効化する。
      // 「土曜を選んだ状態で月曜チップを押す」と必ず0件になるような、
      // 日付と曜日の不自然な組み合わせを防ぐため。日付を1つでも選ぶと日付モードに入る。
      const dateMode = selectedDates.size > 0;
      // 曜日セクション全体をグレーアウト＋クリック不可にする（見た目は CSS 側の .is-locked が担当）
      if (weekdaySection) weekdaySection.classList.toggle('is-locked', dateMode);
      // 各曜日チェックボックスの状態を、日付モードかどうかで切り替える
      weekdayCheckboxes.forEach((c) => {
        if (dateMode) {
          c.checked = false; // 日付モードに入ったら、選んでいた曜日はいったん解除する
          c.disabled = true; // キーボード操作でも触れないよう無効化する
        } else {
          // 日付モードを抜けたら再び有効化。ただし「そもそも空席が無い曜日」は
          // ビルド時にラベルへ is-disabled が付いているので、その曜日は無効のまま保つ。
          const label = c.closest('label');
          c.disabled = label?.classList.contains('is-disabled') ?? false;
        }
      });

    // タグ：判定用は id、表示用はラベル（チェックボックスの隣の span のテキスト）を取る
    const selectedTags = checkboxes.filter((c) => c.checked).map((c) => c.value);
      const selectedTagLabels = checkboxes
        .filter((c) => c.checked)
        .map((c) => c.closest('label')?.querySelector('span')?.textContent?.trim() ?? c.value);
    
      // 曜日：判定用は数値文字列（'0'〜'6'）、表示用は対応表で名前に変換
      const selectedWeekdays = weekdayCheckboxes
        .filter((c) => c.checked)
        .map((c) => c.value);
      const selectedWeekdayLabels = selectedWeekdays.map((v) => WEEKDAY_LABELS[v] ?? v);
    
      let visibleCount = 0;
      items.forEach((item) => {
        const show = matches(item, selectedTags, selectedWeekdays);
        item.classList.toggle('is-hidden', !show);
        if (show) visibleCount += 1;
      });
      // ※件数と「該当なし」の表示は、A（グリッド）/B（日付ブロック）で出し方が変わるため
      //   apply() の末尾でモードごとにまとめて更新する（ここでは計算だけ）。

      // 開催日：選んだ日付を 'YYYY/M/D' で列挙（未選択なら「すべて」）
      if (summaryDates) {
        if (selectedDates.size === 0) {
          summaryDates.textContent = 'すべて';
        } else {
          const formatted = [...selectedDates]
            .sort() // 'YYYY-MM-DD'（ゼロ埋め済み）なので文字列ソート＝日付の早い順
            .map((ds) => {
              const parts = ds.split('-'); // ['2026','07','05']
              // 先頭ゼロを外して '2026/7/5' の形に（Number で 07 → 7）
              return `${parts[0]}/${Number(parts[1])}/${Number(parts[2])}`;
            });
          summaryDates.textContent = formatted.join(', ');
        }
      }
    
      // 曜日：選んだ曜日名を列挙。
      // ただし日付モード中は曜日で絞り込めない（A案でロック済み）ので、
      // 「すべて」ではなく「---」を出して『この軸は今使っていない』ことを示す。
      if (summaryWeekdays) {
        if (dateMode) {
          summaryWeekdays.textContent = '---'; // 日付モード中は曜日の絞り込みは無効
        } else {
          summaryWeekdays.textContent =
            selectedWeekdayLabels.length === 0 ? 'すべて' : selectedWeekdayLabels.join(', ');
        }
      }
    
      // フェア内容：選んだタグ名を列挙
        if (summaryTags) {
          summaryTags.textContent =
            selectedTagLabels.length === 0 ? 'すべて' : selectedTagLabels.join(', ');
        }
      
        // --- 同日まとめブロックの表示更新（案X：タグ・曜日の絞り込みを連動） ---
      // タグを1つでも選んでいる間は、ブロック内を「代表＋折りたたみ」ではなく
      // 「タグに合うカードを全部フラット表示」に切り替える（is-tagfiltered）。
      const tagMode = selectedTags.length > 0;
      // B側に実際に表示されるフェアの数（同じフェアが複数日に出ても data-fair-id で1回だけ数える）。
      const samedayFairIds = new Set<string>();
      let anySameday = false;

samedayBlocks.forEach((block) => {
        const date = block.dataset.samedayDate || '';
        // ※割り切り：特定日を選んだら曜日チップは無視する。よってブロック側では曜日を見ない
        //   （weekday / weekdayOk はここでは使わないので定義ごと削除した）。
      
        // 日付が選ばれているか
        const dateSelected = selectedDates.has(date);
      
        // このブロック内のカードをタグでフィルタ（AND）。残った枚数を数える。
        const cards = Array.from(
          block.querySelectorAll<HTMLElement>('.fair-sameday__card'),
        );
        let visibleCards = 0;
        cards.forEach((card) => {
          // カードが持つタグ集合。選んだタグを「すべて」含むか（AND）
          const own = new Set((card.dataset.tagIds || '').split(' ').filter(Boolean));
          const tagOk = selectedTags.every((id) => own.has(id));
          card.classList.toggle('is-hidden', !tagOk);
          if (tagOk) {
            visibleCards += 1;
            // 件数の重複防止：実際に表示されるフェアのIDを集める（曜日は見ない）
            if (dateSelected) samedayFairIds.add(card.dataset.fairId || '');
          }
        });
      
        // ブロックを出す条件：日付が選択済み・タグで残ったカードが1枚以上（曜日は条件から外した）
        const showBlock = dateSelected && visibleCards > 0;
        block.classList.toggle('is-current', showBlock);
        // タグ絞り込み中は折りたたみを解除して全件フラット表示
        block.classList.toggle('is-tagfiltered', tagMode);
        if (showBlock) anySameday = true;
      });
      if (samedayWrap) samedayWrap.classList.toggle('is-active', anySameday);

    // 案X：日付を1つでも選んでいる間は、通常グリッドを隠して日付ブロックだけ見せる。
      // （dateMode は apply() 冒頭で算出済みなので、ここでは再宣言せず使い回す）
      grid.classList.toggle('is-date-mode', dateMode);

      // 件数と「該当なし」をモードごとに確定させる。
      if (dateMode) {
        // B（日付ブロック）モード：ブロック側の実表示から決める
        if (countEl) countEl.textContent = String(samedayFairIds.size);
        if (noResult) noResult.hidden = anySameday; // 表示ブロックが0件なら該当なしを出す
      } else {
        // A（通常グリッド）モード：従来どおりグリッドの表示枚数で判定
        if (countEl) countEl.textContent = String(visibleCount);
        if (noResult) noResult.hidden = visibleCount > 0;
      }
    };

    // --- カレンダーの月切り替え ---
    const showMonth = (targetIndex: number) => {
      monthBlocks.forEach((block) => {
        const idx = Number(block.dataset.monthIndex);
        block.hidden = idx !== targetIndex;
      });
    };
    navButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        showMonth(Number(btn.dataset.goto));
      });
    });

    // --- 日付マスのクリックで選択トグル ---
    dayCells.forEach((cell) => {
      cell.addEventListener('click', () => {
        const date = cell.dataset.date || '';
        if (!date) return;
        // すでに選択済みなら解除、未選択なら追加（トグル）。
        // Set への add/delete と、マスの見た目（is-selected）を必ずセットで切り替える。
        if (selectedDates.has(date)) {
          selectedDates.delete(date);
          cell.classList.remove('is-selected');
        } else {
          selectedDates.add(date);
          cell.classList.add('is-selected');
        }
        apply(); // 選択状態が変わったので表示を更新
      });
    });

   // --- タグのチェック変更で反映 ---
   checkboxes.forEach((c) => c.addEventListener('change', apply));
   
   // --- 曜日のチェック変更で反映 ---
    weekdayCheckboxes.forEach((c) => c.addEventListener('change', apply));
   
     // --- 同日ブロックの「その他N件」折りたたみ開閉（案X） ---
     // ブロックはビルド時に静的に出力済みなので、リスナーは読み込み時に一度だけ付ければよい。
     samedayToggles.forEach((btn) => {
       btn.addEventListener('click', () => {
         // 押したボタンと同じブロック内のカード群(.fair-sameday__cards)を探して開閉する
         const cards = btn
           .closest('.fair-sameday__content')
           ?.querySelector('.fair-sameday__cards');
         if (!cards) return;
         const willOpen = !cards.classList.contains('is-open');
         cards.classList.toggle('is-open', willOpen);
         // aria-expanded を切り替え（CSSがこの値でボタンの文言を出し分ける）
         btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
       });
     });

    // --- 「条件を解除する」：タグ・日付をすべてリセットし、最初の月に戻す ---
    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        checkboxes.forEach((c) => (c.checked = false));
        weekdayCheckboxes.forEach((c) => (c.checked = false)); // 曜日もリセット
        selectedDates.clear();
        dayCells.forEach((cell) => cell.classList.remove('is-selected'));
        // 同日ブロックの折りたたみも初期状態(閉じ)に戻す（案X）
        document
          .querySelectorAll('.fair-sameday__cards')
          .forEach((cards) => cards.classList.remove('is-open'));
        samedayToggles.forEach((btn) => btn.setAttribute('aria-expanded', 'false'));
        showMonth(0);
        apply();
      });
    }

    // 初期表示（何も選んでいない＝全件表示）
    apply();
  }
</script>
