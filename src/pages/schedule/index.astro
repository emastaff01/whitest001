---
// ビルド時にJSONを読み込む
import scheduleData from '../../data/schedule.json';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url';

const { steps } = scheduleData;

// 画像パス（base 付き安全連結）。他ページと同じ作り方。
// url() は画面内リンク専用なので画像には使わず、この toAssetPath を使う（§2・§7）
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const toAssetPath = (src: string) => `${base}${src}`;
const toWebpPath = (src: string) => toAssetPath(src).replace(/\.jpg$/, '.webp');
---

<BaseLayout title="結婚式までのスケジュール | ホワイトハウス伊万里">

  <div class="sch-wrap">

    <!-- ページヘッダー -->
    <header class="sch-header">
      <p class="sch-header__sub">Wedding Timeline</p>
      <h1 class="sch-header__title">結婚式までのスケジュール</h1>
      <p class="sch-header__lead">
        「何から始めればいいかわからない」という方へ。<br>
        式場見学から挙式当日まで、流れをわかりやすくご紹介します。
      </p>
    </header>

    <!-- タイムライン -->
    <ol class="sch-timeline">
      {steps.map((step, i) => (
        <li class={`sch-step ${step.id === 'step-09' ? 'sch-step--last' : ''}`}>

          {/* 番号バッジ */}
          <div class="sch-step__badge">
            {i < steps.length - 1
              ? <span class="sch-step__num">{String(i + 1).padStart(2, '0')}</span>
              : <span class="sch-step__num sch-step__num--day">当日</span>
            }
          </div>

          {/* 線（最後のステップには引かない） */}
          {i < steps.length - 1 && <div class="sch-step__line" />}

          {/* コンテンツ */}
          <div class="sch-step__body">

            {/* 左：テキスト（従来の中身をそのまま包んだだけ） */}
            <div class="sch-step__text">
              <p class="sch-step__period">{step.period}</p>
              <h2 class="sch-step__title">{step.title}</h2>
              <p class="sch-step__desc">{step.description}</p>
              {step.tips && (
                <p class="sch-step__tips">
                  <span class="sch-step__tips-label">ポイント</span>
                  {step.tips}
                </p>
              )}
            </div>

            {/* 右：画像。flow01.jpg〜flow09.jpg をステップ番号 i+1 に対応させて出す */}
            <div class="sch-step__image">
              <picture>
                <source
                  type="image/webp"
                  srcset={toWebpPath(`/images/schedule/flow${String(i + 1).padStart(2, '0')}.jpg`)}
                />
                <img
                  src={toAssetPath(`/images/schedule/flow${String(i + 1).padStart(2, '0')}.jpg`)}
                  alt={step.title}
                  width="800"
                  height="600"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>

          </div>

        </li>
      ))}
    </ol>

    <!-- CTA：来館誘導 -->
    <div class="sch-cta">
      <p class="sch-cta__lead">
        まずは式場の雰囲気を見てみませんか？<br>
        フェアへのご参加は無料、お気軽にどうぞ。
      </p>
      <div class="sch-cta__btns">
        <a href={url('/fair/')} class="sch-cta__btn sch-cta__btn--primary">
          フェアを見る
        </a>
        <a href={url('/diagnosis/')} class="sch-cta__btn sch-cta__btn--secondary">
          式のスタイルを診断する
        </a>
      </div>
    </div>

  </div>

  <style>
    .sch-wrap {
      max-width: 760px;
      margin: 0 auto;
      padding: 4rem 1.5rem 6rem;
    }

    /* ヘッダー */
    .sch-header {
      text-align: center;
      margin-bottom: 4rem;
    }
    .sch-header__sub {
      font-size: 0.8rem;
      letter-spacing: 0.15em;
      color: var(--bronze);
      margin-bottom: 0.5rem;
    }
    .sch-header__title {
      font-size: clamp(1.6rem, 4vw, 2.2rem);
      margin-bottom: 1rem;
    }
    .sch-header__lead {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #666;
    }

    /* タイムライン全体 */
    .sch-timeline {
      list-style: none;
      padding: 0;
      margin: 0 0 5rem;
      position: relative;
    }

    /* 各ステップ */
    .sch-step {
      display: grid;
      /* 左：バッジ幅、右：コンテンツ */
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto 1fr;
      column-gap: 1.5rem;
      margin-bottom: 0;
    }

    /* バッジ（番号の丸） */
    .sch-step__badge {
      grid-column: 1;
      grid-row: 1;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding-top: 0.1rem;
      /* z-indexを上げて線より前面に */
      position: relative;
      z-index: 1;
    }
    .sch-step__num {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--bronze);
      color: #fff;
      font-size: 0.8rem;
      letter-spacing: 0.05em;
      flex-shrink: 0;
    }
    /* 当日バッジは少し大きめ・強調 */
    .sch-step__num--day {
      font-size: 0.7rem;
      background: var(--green, #4a6741);
    }

    /* バッジとコンテンツをつなぐ縦線 */
    .sch-step__line {
      grid-column: 1;
      grid-row: 2;
      /* バッジの中心に合わせて縦線を引く */
      width: 2px;
      background: #d4c9bc;
      margin: 0 auto;
      /* コンテンツの下部マージン分を含めて線を伸ばす */
      min-height: 2rem;
    }

    /* コンテンツ */
    .sch-step__body {
      grid-column: 2;
      /* バッジ行とライン行をまとめて使う */
      grid-row: 1 / 3;
      padding-bottom: 2.5rem;
      display: flex;
      gap: clamp(1rem, 2.5vw, 1.75rem);
      align-items: flex-start;
    }
    .sch-step__text {
      flex: 1;
      min-width: 0;
    }
    .sch-step__image {
      flex: 0 0 38%;
    }
    .sch-step__image img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: var(--radius, 2px);
    }
    @media (max-width: 600px) {
      .sch-step__body {
        flex-direction: column;
      }
      .sch-step__image {
        flex: none;
        width: 100%;
      }
    }
    
    .sch-step--last .sch-step__body {
      padding-bottom: 0;
    }

    .sch-step__period {
      font-size: 0.78rem;
      color: var(--bronze);
      letter-spacing: 0.08em;
      margin-bottom: 0.3rem;
    }
    .sch-step__title {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      margin-bottom: 0.6rem;
      line-height: 1.5;
    }
    .sch-step__desc {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #555;
      margin-bottom: 0.75rem;
    }

    /* ポイント */
    .sch-step__tips {
      font-size: 0.82rem;
      line-height: 1.7;
      color: #777;
      background: #faf7f4;
      border-left: 2px solid var(--bronze);
      padding: 0.6rem 0.9rem;
      margin: 0;
    }
    .sch-step__tips-label {
      display: inline-block;
      font-size: 0.7rem;
      color: var(--bronze);
      border: 1px solid var(--bronze);
      border-radius: 2px;
      padding: 0.05rem 0.4rem;
      margin-right: 0.5rem;
      vertical-align: middle;
      line-height: 1.6;
    }

    /* CTA */
    .sch-cta {
      text-align: center;
      padding: 3rem 1.5rem;
      border: 1px solid #d4c9bc;
      border-radius: var(--radius, 2px);
    }
    .sch-cta__lead {
      font-size: 0.95rem;
      line-height: 1.8;
      margin-bottom: 1.75rem;
    }
    .sch-cta__btns {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    .sch-cta__btn {
      display: inline-block;
      padding: 0.8rem 2rem;
      font-size: 0.9rem;
      border-radius: var(--radius, 2px);
      text-decoration: none;
      transition: background 0.2s, color 0.2s, border-color 0.2s;
    }
    .sch-cta__btn--primary {
      background: var(--bronze);
      color: #fff;
      border: 1px solid var(--bronze);
    }
    .sch-cta__btn--primary:hover {
      opacity: 0.85;
    }
    .sch-cta__btn--secondary {