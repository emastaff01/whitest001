---
// =============================================================
// src/pages/admin/index.astro
// -------------------------------------------------------------
// =============================================================

import '../../styles/admin.css';
import FairPanel from '../../components/admin/FairPanel.astro';
import PlanPanel from '../../components/admin/PlanPanel.astro';
import NewsPanel from '../../components/admin/NewsPanel.astro';
import ReportPanel from '../../components/admin/ReportPanel.astro';
import BannerPanel from '../../components/admin/BannerPanel.astro';
import TaxonomyPanel from '../../components/admin/TaxonomyPanel.astro';
import SiteSettingsPanel from '../../components/admin/SiteSettingsPanel.astro';
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>管理画面｜ホワイトハウス伊万里</title>
  </head>
  <body>
  <section id="login-screen" class="login" hidden>
    <div class="login__title__card">
      <img src="./images/logo-placeholder.png" alt="ホワイトハウス伊万里" width="80px" height="auto">
      <h1 class="login__title">管理画面ログイン</h1>
      <p class="login__lead">ホワイトハウス伊万里</p>
    </div>
    <div class="login__card">
      <!-- form の既定動作（送信→ページ再読込）は JS 側で止める -->
      <form id="login-form" class="login__form">
        <label class="login__field">
          <span class="login__label">メールアドレス</span>
          <!-- type=email / required でブラウザ標準チェックを効かせる（既存フォームと同じ流儀） -->
          <input type="email" id="login-email" class="login__input"
                 autocomplete="username" required />
        </label>
  
        <label class="login__field">
          <span class="login__label">パスワード</span>
          <input type="password" id="login-password" class="login__input"
                 autocomplete="current-password" required />
        </label>
  
        <!-- ログイン失敗時のメッセージ枠（最初は空＆hidden、role=alert で読み上げ対応） -->
        <p id="login-error" class="login__error" role="alert" hidden></p>
  
        <button type="submit" id="login-submit" class="login__button">ログイン</button>
      </form>
    </div>
  </section>
    <div class="adm-shell" id="admin-shell" hidden>
      <!-- 左サイドバー：タブ。data-tab の値で、表示するパネル（data-panel）を選ぶ -->
      <aside class="adm-side">
        <div class="adm-side__brand">ホワイトハウス伊万里<br />管理画面（テスト）</div>
        <nav class="adm-nav">
          <button type="button" class="adm-tab is-active" data-tab="dashboard">ダッシュボード</button>
          <div class="adm-navgroup">
            <details open>
            <summary><div class="adm-navgroup__title">ブライダルフェア</div></summary>
            <button type="button" class="adm-tab adm-tab--sub" data-tab="fair">フェア管理</button>
            <button type="button" class="adm-tab adm-tab--sub" data-tab="fair-tax">タグ管理</button>
            </details>
          </div>
          <div class="adm-navgroup">
            <details open>
              <summary><div class="adm-navgroup__title">ブライダルプラン</div></summary>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="plan">プラン管理</button>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="plan-tax">タグ管理</button>
            </details>
          </div>
          <div class="adm-navgroup">
            <details open>
              <summary><div class="adm-navgroup__title">お知らせ</div></summary>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="news">お知らせ管理</button>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="news-tax">カテゴリー管理</button>
            </details>
          </div>
          <div class="adm-navgroup">
            <details open>
              <summary><div class="adm-navgroup__title">ウェディングレポート</div></summary>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="report">レポート管理</button>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="report-tax">タグ管理</button>
            </details>
          </div>
          <div class="adm-navgroup">
            <details open>
              <summary><div class="adm-navgroup__title">その他</div></summary>
              <button type="button" class="adm-tab adm-tab--sub" data-tab="banner">
                バナー管理
              </button>
            </details>
          </div>
          <button type="button" class="adm-tab" id="logout-btn">ログアウト</button>
        </nav>
        <hr class="adm-nav-divider" />
        <button class="adm-tab" data-tab="site-settings">サイト設定</button>
        <small>&copy;memolead.</small>
      </aside>

      <!-- 右メイン：各タブの中身（パネル）。hidden が付いたパネルは隠れる -->
      <main class="adm-main">
        <!-- ダッシュボード（初期表示） -->
        <section class="adm-panel adm-dash" data-panel="dashboard">
          <h1 class="adm-panel__title">ダッシュボード</h1>

          <div class="adm-note">
            <h3>使い方</h3>
            <ol>
              <li>各タブで内容を編集する</li>
              <li>「Firestore に保存」でデータベースに保存する</li>
            </ol>
            <p>※公開サイトへの反映（自動ビルド）は今後実装予定です。現在のテスト環境では、保存しても公開サイトにはまだ反映されません。</p>
          </div>

          <div class="adm-note">
            <h3>注意</h3>
            <ul>
              <li>編集内容は「Firestore に保存」を押した時点で保存されます。保存前に画面を離れると反映されません。</li>
              <li>ページを再読み込みすると、保存していない編集内容は消えます（タブの切り替えでは消えません）。</li>
              <li>コンタクト履歴は、送信ログの保存処理を実装してから有効化します。</li>
            </ul>
          </div>
        </section>

        <FairPanel />
        <TaxonomyPanel
          tabKey="fair-tax"
          title="フェアのタグ管理"
          groups={[
            { "group": "fair-tags",     "groupLabel": "フェアのタグ",   "idPrefix": "ft-" },
            { "group": "fair-contents", "groupLabel": "体験できること", "idPrefix": "fc-", "withIcon": true }
          ]}
        />
        <PlanPanel />
        <TaxonomyPanel
          tabKey="plan-tax"
          title="プランのタグ管理"
          groups={[
            { "group": "plan-includes", "groupLabel": "含まれるもの", "unitLabel": "項目",    "idPrefix": "pi-" },
            { "group": "plan-tags",     "groupLabel": "対象スタイル", "unitLabel": "スタイル", "idPrefix": "pt-" }
          ]}
        />
        <NewsPanel />
        <TaxonomyPanel
          tabKey="news-tax"
          title="お知らせカテゴリー管理"
          groups={[
            { "group": "news-category", "groupLabel": "カテゴリー", "unitLabel": "カテゴリー", "idPrefix": "nc-" }
          ]}
        />
        <ReportPanel />
        <TaxonomyPanel
          tabKey="report-tax"
          title="レポートのタグ管理"
          groups={[
            { "group": "report-tags", "groupLabel": "タグ", "unitLabel": "タグ", "idPrefix": "rt-" }
          ]}
        />
        <BannerPanel />
        
<div data-panel="site-settings" hidden>
              <SiteSettingsPanel />
            </div>
          </main>
        </div><!-- /.adm-shell -->
        
<!-- OGP画像ピッカー（SiteSettingsPanel 用） -->
        <div class="adm-picker" id="ss-ogp-picker" hidden>
          <div class="adm-picker__backdrop" id="ss-ogp-picker-close"></div>
          <div class="adm-picker__panel" role="dialog" aria-label="OGP画像を選択">
            <div class="adm-picker__head">
              <span class="adm-picker__title">OGP画像を選択</span>
              <button type="button" class="adm-picker__close" id="ss-ogp-picker-close-btn">✕</button>
            </div>
            <div class="adm-picker__grid" id="ss-ogp-picker-grid"></div>
            <div class="adm-picker__footer">
              <button type="button" class="adm-btn adm-btn--primary" id="ss-ogp-picker-confirm">
                選択する
              </button>
            </div>
          </div>
        </div>        
        <script>
    // 認証の入口（firebase.ts でエクスポートした auth）
    import { auth } from '../../lib/firebase';
    // ログイン/ログアウト/状態監視の関数
    // ※ Firebase の signOut は自作の signOut と名前が衝突するので fbSignOut に別名化
    import {
      signInWithEmailAndPassword,
      signOut as fbSignOut,
      onAuthStateChanged,
    } from 'firebase/auth';
    
    // ===== 認証（Firebase Auth 版） =====
    
    // ログイン処理：Firebase に email/password で認証を依頼。成功で true、失敗で false。
    // 仮実装と同じ「true/false を返す」形を保つので、呼び出し側は await を足すだけで済む。
    const signIn = async (email: string, password: string): Promise<boolean> => {
      try {
        await signInWithEmailAndPassword(auth, email, password);
        return true;
      } catch (e) {
        // パスワード違い・ユーザー無しなどはここに来る（throw されるため）
        console.error('ログイン失敗:', e);
        return false;
      }
    };
    
    // ログアウト処理：Firebase のセッションを破棄
    const signOut = async (): Promise<void> => {
      await fbSignOut(auth);
    };
    
    // ログイン状態の監視：状態が変わるたびに callback(user) が呼ばれる。
    // user があればログイン中、null なら未ログイン。
    // ＝ 仮実装の「if (isLoggedIn()) ... else ...」の置き換え先。
    const onAuthChanged = (callback: (loggedIn: boolean) => void): void => {
      onAuthStateChanged(auth, (user) => callback(user !== null));
    };
    
    // ===== 画面の出し分け（ログイン画面 ⇔ 管理シェル） =====
    const loginScreen = document.querySelector<HTMLElement>('#login-screen');
    const adminShell  = document.querySelector<HTMLElement>('#admin-shell'); // ←シェルに付けるid
    const loginForm   = document.querySelector<HTMLFormElement>('#login-form');
    const loginEmail  = document.querySelector<HTMLInputElement>('#login-email');
    const loginPass   = document.querySelector<HTMLInputElement>('#login-password');
    const loginError  = document.querySelector<HTMLElement>('#login-error');
    const loginBtn    = document.querySelector<HTMLButtonElement>('#login-submit');
    
    // ok（ログイン中か）を引数で受け取る。判定は onAuthChanged が握る。
    const renderAuth = (ok: boolean): void => {
      if (loginScreen) loginScreen.hidden = ok;   // ログイン済みなら門を隠す
      if (adminShell)  adminShell.hidden  = !ok;  // 未ログインなら中身を隠す
    };
    
// 必要な要素が全部揃っているときだけフォーム処理を付ける（null安全）
    if (loginForm && loginEmail && loginPass && loginError && loginBtn) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();               // 送信によるページ再読込を止める
        loginError.hidden = true;         // 前回のエラー表示を消す
        loginBtn.disabled = true;         // 二重送信防止
        loginBtn.textContent = 'ログイン中…';
    
        const ok = await signIn(loginEmail.value.trim(), loginPass.value);
        if (!ok) {
          loginError.textContent = 'メールアドレスまたはパスワードが違います。';
          loginError.hidden = false;
        }
        // 成功時は onAuthChanged が renderAuth(true) を呼ぶので、ここでは表示切替しない。
    
        loginBtn.disabled = false;        // 失敗時に再入力できるよう戻す（成功時は隠れるので無害）
        loginBtn.textContent = 'ログイン';
      });
    }
    
    // （任意）ログアウトボタンがあれば紐付け
    const logoutBtn = document.querySelector<HTMLButtonElement>('#logout-btn');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', async () => {
        // ログアウトすると作業中の内容は破棄されるので、未保存があれば確認する
        if (!confirmLeave(currentKey)) return;
        await signOut();
      });
      // signOut 後に onAuthChanged が renderAuth(false) を呼んでログイン画面に戻る
    }
    
    // ログイン状態が変わるたびに表示を更新（初回読み込み時にも1回呼ばれる）。
    // ＝ ログイン成功 / ログアウト / 再読込（セッション復元）すべてここで表示が決まる。
    onAuthChanged((loggedIn) => renderAuth(loggedIn));
    
      // タブ切り替え
      // const のアロー関数＋型注釈で、astro check（厳格な型チェック）に通るようにする。
      const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.adm-tab'));
      const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-panel]'));

      // いま表示中のタブ。未保存確認で「どのパネルから離れるか」を知るために覚えておく。
      let currentKey = '';

      // 指定パネルに未保存があれば、一覧付きで確認する。続行してよければ true、引き止めるなら false。
      // 各パネルが window.adminDirtyReporters[パネル名] に「未保存ラベル配列を返す関数」を登録している。
      // （登録が無いパネルは未保存追跡なし＝素通り。現状はフェアのみ登録）
      const confirmLeave = (fromKey: string): boolean => {
        const reporters =
          (window as unknown as { adminDirtyReporters?: Record<string, () => string[]> })
            .adminDirtyReporters ?? {};
        const report = reporters[fromKey];
        if (!report) return true;
        const items = report();
        if (items.length === 0) return true; // 未保存なし
        const list = items.join('\n'); // ラベルは既に【修正】等の形なので、そのまま改行で並べる
        return window.confirm(
          '保存していない変更があります。タブを切り替えますか？\n' +
            '（変更は保持され、戻れば続きを編集できます）\n\n' +
            list
        );
      };

      // key（'dashboard' / 'fair' ...）のパネルだけ表示し、対応タブを active にする
      const show = (key: string): void => {
        currentKey = key; // 表示中タブを更新（次回の離脱確認で使う）
        panels.forEach((p) => {
          // hidden 属性の付け外しで表示・非表示（CSS の [hidden]{display:none} が効く）
          p.hidden = p.dataset.panel !== key;
        });
        tabs.forEach((t) => {
          const active = t.dataset.tab === key;
          t.classList.toggle('is-active', active);
          // スクリーンリーダー向けに「今ここ」を伝える
          if (active) t.setAttribute('aria-current', 'page');
          else t.removeAttribute('aria-current');
        });
      };

      tabs.forEach((t) => {
        t.addEventListener('click', () => {
          if (t.disabled) return; // 準備中タブは無視
          const key = t.dataset.tab;
          if (!key) return;
          if (key === currentKey) return;        // 同じタブなら何もしない
          if (!confirmLeave(currentKey)) return; // 未保存確認でキャンセルされたら切り替えない
          show(key);
          // URL末尾に #fair などを付ける。再読み込みしても同じタブを開ける（保存ではない）
          history.replaceState(null, '', '#' + key);
        });
      });

      // 起動時：URLの #... が有効なタブならそれを、なければダッシュボードを開く
      const initial = location.hash.replace('#', '');
      const isValid = tabs.some((t) => t.dataset.tab === initial && !t.disabled);
      show(isValid ? initial : 'dashboard');
    </script>
  </body>
</html>