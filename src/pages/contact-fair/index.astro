---
// src/pages/contact-fair/index.astro
// 共通のお問い合わせフォームページ
// 今回は「画面（入力欄・入力チェック）」のみ。送信処理（メール送信）は後日実装。

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/common/PageHeader.astro";
import { url } from "../../lib/url";
import { getFairs } from "../../lib/getFairs"; 

// ビルド時に公開中フェアを取得し、{ id: 表示名 } の早見表を作る
const fairs = getFairs(); // get〜が同期でも await を付けて問題なし（将来Firestore=非同期化にも耐える）

// 早見表（IDからフェア名を引く対応表）。
// URLの ?fair_id= には fair.reservationFormId ?? fair.id が入る（fair/[id].astro 参照）。
// そのため id と reservationFormId の両方をキーにして、どちらの値が来てもフェア名を引けるようにする。
const fairNames: Record<string, string> = {}; // キー・値ともに文字列のオブジェクトだと型で明示
for (const f of fairs) {
  fairNames[f.id] = f.title; // まず id で引けるよう登録
  if (f.reservationFormId) {
	// reservationFormId が設定されているフェアは、その値でも同じ名前を引けるよう追加登録
	fairNames[f.reservationFormId] = f.title;
  }
}

const pageTitle = "お問い合わせ";
const pageDescription = "ホワイトハウス伊万里へのお問い合わせはこちらから。";
const thanksUrl = url("/contact-fair/thanks/");
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageHeader title="お問い合わせ" overline="CONTACT FAIR" />

  <section class="contact">
	<div class="contact__inner">
	  <p class="contact__lead">
		ご見学・各種ご相談など、お気軽にお問い合わせください。<br />
		<span class="contact__required-note">「<span class="required-mark">必須</span>」の項目は必ずご入力ください。</span>
	  </p>

	  {/* novalidate は付けない＝ブラウザ標準の入力チェックを活かす */}
	  {/* action / method は送信処理を実装する段階で設定する。今はあえて未設定 */}
	  <form class="contact-form" id="contactForm">
	  {/* お問い合わせ対象（フェア名）。JSがURLのIDから名前を引いて表示。該当なしは非表示のまま */}
	  <p id="contactTarget" class="contact__target" hidden></p>
	  <p id="contactDatetime" class="contact__target" hidden></p>
	  
	  {/* 送る情報 */}
	  <input type="hidden" id="fairId" name="fair_id" />
	  <input type="hidden" id="dateField" name="date" />
	  <input type="hidden" id="timeField" name="time" />
	  
	  {/* お問い合わせ内容（任意） */}
	 <div class="form-row" hidden>
	   <label class="form-label" for="category">お問い合わせ内容</label>
		<select class="form-control" id="category" name="category">
		  <option value="">選択してください</option>
		  <option value="visit">来館予約</option>
			<option value="inquiry">お問い合わせ</option>
			<option value="document">資料請求</option>
			<option value="other">その他</option>
		</select>
	  </div>

		{/* お名前（必須） */}
		<div class="form-row">
		  <label class="form-label" for="name">
			お名前<span class="required-mark">必須</span>
		  </label>
		  <input
			class="form-control"
			type="text"
			id="name"
			name="name"
			required
			autocomplete="name"
			placeholder="例：山田 花子"
		  />
		</div>

		{/* フリガナ（任意） */}
		<div class="form-row">
		  <label class="form-label" for="kana">フリガナ<span class="required-mark">必須</span></label>
		  <input
			class="form-control"
			type="text"
			id="kana"
			name="kana"
			autocomplete="off"
			required
			placeholder="例：ヤマダ ハナコ"
		  />
		</div>

		{/* メールアドレス（必須）type="email" でメール形式かを自動チェック */}
		<div class="form-row">
		  <label class="form-label" for="email">
			メールアドレス<span class="required-mark">必須</span>
		  </label>
		  <input
			class="form-control"
			type="email"
			id="email"
			name="email"
			required
			autocomplete="email"
			placeholder="例：info@example.com"
		  />
		</div>

		{/* 電話番号　inputmode でスマホに数字キーボードを出す */}
		<div class="form-row">
		  <label class="form-label" for="tel">電話番号<span class="required-mark">必須</span></label>
		  <input
			class="form-control"
			type="tel"
			id="tel"
			name="tel"
			inputmode="tel"
			autocomplete="tel"
			required
			placeholder="例：0955-00-0000"
		  />
		</div>
		
		{/* お問い合わせ内容（必須） */}
		<div class="form-row">
		  <label class="form-label" for="message">
			お問い合わせ内容
		  </label>
		  <textarea
			class="form-control"
			id="message"
			name="message"
			rows="6"
			placeholder="ご質問・ご相談内容をご記入ください。"
		  ></textarea>
		</div>

		{/* プライバシーポリシー同意（必須） */}
		<div class="form-row form-row--check">
		  <label class="form-check">
			<input type="checkbox" name="agree" value="yes" required />
			<span>
			  <a href="https://www.memolead.co.jp/privacy/" class="contact__link">プライバシーポリシー</a>に同意します<span class="required-mark">必須</span>
			</span>
		  </label>
		</div>

		<div class="form-actions">
		  <button type="submit" class="form-submit">送信する</button>
		</div>
		<p id="formStatus" role="status"></p>{/*内容が変わったとき読み上げソフトに知らせる属性*/}
	  </form>
	</div>
  </section>
</BaseLayout>
<script type="application/json" id="fairNamesData" is:inline set:html={JSON.stringify(fairNames)}></script>
<script is:inline define:vars={{ thanksUrl }}>
  // 送信処理を実装。HTML標準バリデーションを通った内容をJSONにまとめ、
  // 段階2でデプロイした Cloudflare Worker（受け口）へ送る。
  // JS無効時でも required / type="email" は機能する（フォールバック）。
  const form = document.getElementById("contactForm");

  // 送信結果の表示先（後述：HTMLに無ければ1行追加）と、送信ボタン
  const statusEl = document.getElementById("formStatus");
  const submitBtn = form ? form.querySelector('button[type="submit"]') : null;
  const originalBtnText = submitBtn ? submitBtn.textContent : "";

  const ENDPOINT = "https://whitehouse-imari-contact-worker.matsufuji.workers.dev";
  const fairNames = JSON.parse(document.getElementById("fairNamesData")?.textContent || "{}");
  
	// URL の ?fair_id=... を読み取り、hidden 項目にセットする
	// （静的サイトはブラウザ側でしかクエリを読めないため、ここで行う）
	const rawFairId = new URLSearchParams(location.search).get("fair_id") || "";
	  const fairId = rawFairId.replace(/\/+$/, ""); // 末尾のスラッシュを除去してIDとして使う
	  const fairIdInput = document.getElementById("fairId");
	  if (fairIdInput) fairIdInput.value = fairId; // 送信値も正規化後のIDにする
	  
	  const params = new URLSearchParams(location.search);
	  const date = params.get("date") || ""; // 値が無ければ空文字（＝後で行が出ない）
	  const time = params.get("time") || ""; // "%3A"（:）は get() が自動でデコードするので "11:00" が得られる
	  const dateInput = document.getElementById("dateField");
	  const timeInput = document.getElementById("timeField");
	  if (dateInput) dateInput.value = date;
	  if (timeInput) timeInput.value = time;
	
	  // フェアIDから表示名を引き、見つかれば画面に出す（無ければ隠したまま）
	  const fairName = fairNames[fairId] || "";
	  const targetEl = document.getElementById("contactTarget");
	  if (targetEl && fairName) {
		targetEl.textContent = "お問い合わせ対象：" + fairName; // textContent=文字として入れる（HTML注入を防ぎ安全）
		targetEl.hidden = false; // hidden を外して表示する
	  }
	  
	  // 希望日時があれば画面に表示（date と time のうち、入っている方だけ並べる）
	  const datetimeEl = document.getElementById("contactDatetime");
	  if (datetimeEl && (date || time)) {
		datetimeEl.textContent = "ご希望日時：" + [date, time].filter(Boolean).join(" ");
		datetimeEl.hidden = false; // hidden を外して表示
	  }
  
	if (form) {
	form.addEventListener("submit", async (event) => {
	  // 既定の送信動作（ページ遷移・リロード）を止める
	  event.preventDefault();

	  // ブラウザ標準の入力チェック。未入力やメール形式エラーがあれば中断
	  if (!form.checkValidity()) {
		form.reportValidity();
		return;
	  }

	  // 二重送信を防ぐため、送信中はボタンを無効化して文言を変える
	  if (submitBtn) {
		submitBtn.disabled = true;
		submitBtn.textContent = "送信中…";
	  }
	  if (statusEl) statusEl.textContent = "";

	  // 入力値を、Worker が受け取る name と同じキーでJSONにまとめる
	  const fd = new FormData(form);
	  const payload = {
		name: fd.get("name"),
		kana: fd.get("kana"),
		email: fd.get("email"),
		tel: fd.get("tel"),
		category: fd.get("category"),
		message: fd.get("message"),
		fair_id: fd.get("fair_id"), // hidden に入れたフェアIDを一緒に送る
		date: fd.get("date"), // 希望日（フェア以外では空 → Worker側で行が出ない）
		time: fd.get("time"), // 希望時間（同上）
		// チェックボックスは値ではなく checked（チェックの有無）を boolean で送る
		agree: form.querySelector('[name="agree"]')?.checked === true,
	  };

	  try {
		// Worker へ POST 送信
		const res = await fetch(ENDPOINT, {
		  method: "POST",
		  headers: { "Content-Type": "application/json" }, // JSONで送ると伝える
		  body: JSON.stringify(payload), // JSオブジェクト→JSON文字列に変換
		});

		// 返事を JSON として読む（壊れていても落ちないよう保険）
		const data = await res.json().catch(() => ({}));

		// HTTP成功 かつ Worker が ok:true を返したときだけ成功扱い
		if (res.ok && data.ok) {
		  window.location.href = thanksUrl; // 成功したらサンクスページへ遷移
		  return; // 以降は不要なのでここで終了
		} else {
		  if (statusEl) statusEl.textContent = "送信に失敗しました。時間をおいて再度お試しください。";
		  console.error("送信失敗", res.status, data); // 原因確認用ログ
		}
	  } catch (err) {
		// 通信自体ができなかった場合（ネット不通・CORSブロックなど）
		if (statusEl) statusEl.textContent = "通信エラーが発生しました。接続を確認して再度お試しください。";
		console.error("通信エラー", err);
	  } finally {
		// 成功・失敗どちらでもボタンを元に戻す
		if (submitBtn) {
		  submitBtn.disabled = false;
		  submitBtn.textContent = originalBtnText; // 元の文言（送信内容を確認する）に戻す
		}
	  }
	});
  }
</script>
<style>
  .contact {
	padding: 48px 16px 80px;
  }
  .contact__inner {
	max-width: 720px;
	margin: 0 auto;
  }
  .contact__lead {
	margin-bottom: 32px;
	line-height: 1.9;
  }
  .contact__required-note {
	font-size: 0.875rem;
	color: #666;
  }
  .contact-form {
	display: flex;
	flex-direction: column;
	gap: 24px;
  }
  .contact__target {
	  margin-bottom: 24px;
	  padding: 12px 16px;
	  background: #f6f2ea;
	  border-left: 4px solid #8a7a5c;
	  border-radius: 4px;
	  font-weight: 600;
	}
  .form-row {
	display: flex;
	flex-direction: column;
	gap: 8px;
  }
  .form-label {
	font-weight: 600;
	display: flex;
	align-items: center;
	gap: 8px;
  }
  .required-mark {
	display: inline-block;
	font-size: 0.6875rem;
	line-height: 1;
	padding: 3px 6px;
	border-radius: 3px;
	background: #c0392b;
	color: #fff;
	font-weight: 600;
  }
  .form-control {
	width: 100%;
	padding: 12px 14px;
	font-size: 1rem;
	border: 1px solid #ccc;
	border-radius: 6px;
	background: #fff;
  }
  .form-control:focus {
	outline: none;
	border-color: #8a7a5c;
	box-shadow: 0 0 0 3px rgba(138, 122, 92, 0.15);
  }
  .form-row--check {
	margin-top: 8px;
  }
  .form-check {
	display: flex;
	align-items: flex-start;
	gap: 10px;
	cursor: pointer;
	line-height: 1.7;
  }
  .form-check input {
	margin-top: 4px;
	width: 18px;
	height: 18px;
	flex-shrink: 0;
  }
  .contact__link {
	color: #8a7a5c;
	text-decoration: underline;
  }
  .form-actions {
	margin-top: 16px;
	text-align: center;
  }
  .form-submit {
	display: inline-block;
	min-width: 240px;
	padding: 16px 32px;
	font-size: 1rem;
	font-weight: 600;
	color: #fff;
	background: #8a7a5c;
	border: none;
	border-radius: 6px;
	cursor: pointer;
	transition: opacity 0.2s ease;
  }
  .form-submit:hover {
	opacity: 0.85;
  }
  @media (max-width: 600px) {
	.form-submit {
	  width: 100%;
	}
  }
</style>