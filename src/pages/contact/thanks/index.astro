---
// src/pages/contact/thanks/index.astro
// お問い合わせ送信後の「ありがとうございました」ページ。
// フォーム送信が成功すると、JS（変更点C）でこのページへ遷移してくる。

import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/common/PageHeader.astro";
import { url } from "../../../lib/url";
// ↑ このファイルは contact/ より1階層深いので、相対パスは ../../../（3つ上がって src）になる

const pageTitle = "お問い合わせ完了";
const pageDescription = "お問い合わせありがとうございました。";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <PageHeader title="送信が完了しました" overline="THANK YOU" />

  <section class="thanks">
	<div class="thanks__inner">
	  <p class="thanks__lead">
		お問い合わせいただき、ありがとうございました。<br />
		担当者より、ご入力いただいたメールアドレスへ追ってご連絡いたします。
	  </p>
	  <p class="thanks__note">
		確認メールが届かない場合は、迷惑メールフォルダをご確認のうえ、
		お手数ですが再度お問い合わせいただくか、お電話にてご連絡ください。
	  </p>

	  <div class="thanks__actions">
		<a href={url("/")} class="thanks__button">トップへ戻る</a>
		<a href={url("/fair/")} class="thanks__button thanks__button--sub">フェアを見る</a>
	  </div>
	</div>
  </section>
</BaseLayout>

<style>
  .thanks__inner {
	max-width: 720px;
	margin: 0 auto;
	padding: 3rem 1.25rem 4rem;
	text-align: center;
  }
  .thanks__lead {
	font-size: 1.0625rem;
	line-height: 1.9;
	margin-bottom: 1.5rem;
  }
  .thanks__note {
	font-size: 0.9375rem;
	line-height: 1.8;
	color: #666;
	margin-bottom: 2.5rem;
  }
  .thanks__actions {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 1rem;
  }
  .thanks__button {
	display: inline-block;
	min-width: 200px;
	padding: 0.9rem 1.5rem;
	background: #b59b6e;
	color: #fff;
	text-decoration: none;
	border-radius: 4px;
	transition: opacity 0.2s ease;
  }
  .thanks__button:hover {
	opacity: 0.85;
  }
  .thanks__button--sub {
	background: transparent;
	color: #b59b6e;
	border: 1px solid #b59b6e;
  }
</style>