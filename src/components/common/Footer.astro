---
// =============================================================
// Footer.astro （全ページ共通のフッター）
// -------------------------------------------------------------
// ・NAP情報（名称・住所・電話）を dl タグで構造化
//   → LLMO/SEOで「事実情報」として機械に読み取られやすくするため
// ・全ページへのサイトマップ
// ・LINE相談ボタン（URLは後日提供のため仮置き）
// =============================================================

import { url } from '../../lib/url';
import { navGroups } from '../../lib/navigation';
import { getSiteSettings } from '../../lib/getSiteSettings';
import CtaButton from './CtaButton.astro';

const settings = getSiteSettings();
const phone = settings.nap.phone;
const telHref = `tel:${phone.replace(/[^0-9]/g, '')}`;
const lineHref = settings.lineUrl || '#';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <p class="footer__brand-en">WHITE HOUSE IMARI</p>
      <p class="footer__brand-jp">{settings.nap.name}</p>

      <dl class="footer__nap">
        <dt>所在地</dt>
        <dd>〒{settings.nap.postalCode}<br />{settings.nap.address}</dd>
        <dt>電話</dt>
        <dd><a href={telHref} data-ga="phoneCV">{phone}</a></dd>
        <dt>アクセス</dt>
        <dd>{settings.access}</dd>
        <dt>営業時間</dt>
        <dd>{settings.businessHours}</dd>
        <dt>定休日</dt>
        <dd>{settings.closedDays}</dd>
      </dl>

      <div class="footer__line">
        <div class="footer__line-text">
          <p>LINEで気軽にご相談いただけます。</p>
          <CtaButton
            href={lineHref}
            variant="line"
            ga="lineCV"
            external={Boolean(settings.lineUrl)}
          >
            LINEで相談する
          </CtaButton>
        </div>
      </div>
    </div>

    <nav class="footer__nav" aria-label="フッターメニュー">
      {
        navGroups.map((group) => (
          <div class="footer__col">
            <p class="footer__col-title">{group.title}</p>
            <ul>
              {group.links.map((link) => (
                <li>
                  <a href={url(link.path)}>{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>

  <div class="footer__bottom">
    <small>&copy; {currentYear} {settings.nap.name}</small>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--off-white);
    color: var(--dark-gray);
  }

  .footer__inner {
    max-width: var(--maxw-content);
    margin-inline: auto;
    padding: var(--space-section-y) var(--space-section-x) 48px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }

  .footer__brand-en {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.7rem;
    color: var(--green);
    letter-spacing: 0.05em;
  }
  .footer__brand-jp {
    font-family: var(--font-jp-serif);
    font-size: 1.25rem;
    color: var(--charcoal);
    margin-top: 6px;
  }

  .footer__nap {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 10px 16px;
    margin-top: 28px;
    font-size: 0.85rem;
  }
  .footer__nap dt {
    color: var(--gray);
  }
  .footer__nap dd {
    color: var(--dark-gray);
    line-height: 1.7;
  }

  .footer__line {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 32px;
    max-width: 420px;
  }
  .footer__line-text p {
    font-size: 0.85rem;
    margin-bottom: 12px;
  }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px 24px;
  }
  .footer__col-title {
    font-family: var(--font-en-label);
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--green);
    padding-bottom: 10px;
    margin-bottom: 14px;
    border-bottom: 0.5px solid var(--hairline-green);
  }
  .footer__col ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer__col a {
    font-size: 0.85rem;
    color: var(--dark-gray);
  }
  .footer__col a:hover {
    color: var(--green);
  }

  .footer__bottom {
    text-align: center;
    padding: 24px var(--space-section-x);
  }
  .footer__bottom small {
    font-family: var(--font-en-label);
    font-size: 0.7rem;
    color: var(--gray);
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr 1.4fr;
      gap: 64px;
    }
    .footer__nav {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
