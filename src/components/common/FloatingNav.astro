---
// 右下に追従するフローティングナビ
// 中身：(1) ブライダルフェアのバナー（常時表示） (2) ページ上部へ戻るボタン（スクロールで出現）
import { url } from '../../lib/url';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string): string => `${BASE}/${p.replace(/^\/+/, '')}`;
const webp = (p: string): string => asset(p).replace(/\.png$/i, '.webp');
const bannerPng = '/images/floating/fair_banner.png';

const diagUrl = url('/diagnosis/'); // 診断ページのURL
---

<div class="floating">
  <!-- 診断バナー（常時表示） -->
  <a href={diagUrl} class="floating__banner" aria-label="結婚式スタイル診断をはじめる">
  <p class="floating__banner-img"><picture>
    <source srcset={webp(bannerPng)} type="image/webp" />
    <img src={asset(bannerPng)} alt="ブライダルフェア実施中！" loading="lazy" decoding="async" />
  </picture></p>
    <span class="floating__banner__inner">
    
    <p class="floating__banner-sub">何も決まってない...<br>自分にあった結婚式がわからない方必見！</p>
    <p class="floating__banner-main">自分に合うスタイルを診断!!<br>結婚式スタイル診断をはじめる</p>
    </span>
    <p class="floating__banner-arrow" aria-hidden="true">→</p>
  </a>

  <!-- ページ上部へ戻るボタン（スクロールすると出現） -->
  <button type="button" class="floating__top" id="floatingTop" aria-label="ページの先頭へ戻る">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M18 15l-6-6-6 6" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    <span class="floating__top-label">TOP</span>
  </button>
</div>

<style>
.floating {
  position: fixed;
  right: 0px;
  bottom: 16px;
  z-index: 90;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12px;
}
.floating__banner {
  display: flex;
  flex-direction: row;
  gap: 3px;
  width: clamp(220px, 22vw, 400px);
  background: var(--red);
  color: var(--white);
  text-decoration: none;
  border-radius: 6px 0 0 6px;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  transition: transform 0.2s ease, opacity 0.2s ease;
  align-items:center;
}
.floating__banner .floating__banner__inner {
display: flex;
flex-direction: column;
padding:8px;
align-self:center;
width:60%;
}
.floating__banner:hover {
  transform: translateY(-2px);
  opacity: 0.9;
}
.floating__banner-img {
 width:30%;
 height:auto;
}
.floating__banner-img img{
 width:100%;
 height:auto;
 object-fit:cover;
 aspect-ratio:1/1;
}
.floating__banner-sub {
  font-family: var(--font-en-label);
  font-size: 0.6rem;
  letter-spacing: 0.1em;
  opacity: 0.8;
  color: var(--white);
}
.floating__banner-main {
  font-size: 0.85rem;
  font-weight: bold;
  line-height: 1.4;
  color: var(--white);
}
.floating__banner-arrow {
  font-size: 1rem;
  margin: 4px 4px 0 0;
  opacity: 0.8;
  color: var(--white);
  width:10%;
  height:auto;
  border:1px solid var(--white);
  border-radius:1.4rem;
  text-align:center;
  line-height:2.2;
}
.floating__top {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  width: 80px;
  height: 80px;
  border: none;
  border-radius: 50%;
  background: var(--green);
  color: var(--white);
  cursor: pointer;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.18);
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s;
}
.floating__top.is-visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}
.floating__top-label {
  font-size: 0.625rem;
  letter-spacing: 0.05em;
  font-family: var(--font-en-label);
}
@media (prefers-reduced-motion: reduce) {
  .floating__top { transition: opacity 0.25s ease; transform: none; }
  .floating__banner { transition: none; }
}
</style>

<script>
  // 「ページ上部へ戻る」ボタンの制御
  // 型チェック(astro check)対策で querySelector に要素型を指定する。
  const topBtn = document.querySelector<HTMLButtonElement>('#floatingTop');

  // 必要な要素が取れたときだけ処理する（null ガード）。
  // 関数は const のアロー関数で定義（function 宣言だと型の絞り込みが効かずエラーになりやすい）。
  if (topBtn) {
    // スクロール量で表示/非表示を切り替える
    const toggle = (): void => {
      // 300px より下までスクロールしたら表示
      if (window.scrollY > 300) {
        topBtn.classList.add('is-visible');
      } else {
        topBtn.classList.remove('is-visible');
      }
    };

    // クリックで最上部へスムーズスクロール
    topBtn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // スクロールのたびに判定（passive: true で描画をブロックしない＝軽い）
    window.addEventListener('scroll', toggle, { passive: true });
    // 初期表示でも一度判定（リロード位置が下の場合に備える）
    toggle();
  }
</script>