---
// =============================================================
// src/components/admin/PlanPanel.astro
// -------------------------------------------------------------
// 管理画面「プラン」タブ。FairPanel.astro と同じ操作体験に揃えたもの。
// 画面構成:
//   ・一覧ビュー：サムネ＋タイトル＋公開バッジ＋価格／含まれるもの／対象スタイル の行を並べる。
//     行クリックで編集ビューへ。
//   ・編集ビュー：1件だけ表示。「一覧に戻る」で戻る／「Firestore に保存」で確定。
//   ・並べ替えモード：一覧の「並べ替える」ボタンで切替。モード中だけ
//     行がドラッグ専用になり（クリックで編集に飛ばない）、≡ で並べ替え。
//
// フェアとの違い（なぜコードが減るのか）:
//   ・プランは「日程（schedule）」を持たない → 時間枠・空き状況まわりのUIと
//     その追加/削除イベント、定員/予約済み/◎△× の計算が丸ごと不要。
//   ・代わりに数値項目（priceFrom 必須 / priceTo 任意 / guestCountBase 任意）と、
//     配列項目（includeIds 含まれるもの / tagIds 対象スタイル）を持つ。
//
// データの流れ（フェアと同じ）:
//   ・表示は常に1件（編集ビュー）。harvest/populate は editingIndex の1件だけ。
//   ・保存は working 全件が対象（戻る/保存の前に harvest して working を最新化）。
//   ・サムネ欄は「表示＝ファイル名／保存＝フルパス（data-fullpath）」、alt はタイトル自動。
//
// 共通のルール:
//   ・要素IDは plan- で始める（同一ページの他パネルとIDが衝突しないように）。
//     ※並べ替えリストの id も #plan-reorder-list にする（フェアの #fair-reorder-list と区別）。
//   ・スタイルは src/styles/admin.css 側。一覧・並べ替えは fair-list*/fair-reorder* を流用する。
// =============================================================

import fs from 'node:fs';

// 画像ピッカー用の一覧をビルド時に作る（public/images/plans/ の .jpg を列挙）。
const PLAN_IMG_DIR = 'public/images/plans';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, ''); // 末尾スラッシュ除去（例 '/test-whi'）
let planImages: { value: string; url: string }[] = [];
if (fs.existsSync(PLAN_IMG_DIR)) {
  planImages = fs
    .readdirSync(PLAN_IMG_DIR)
    .filter((f) => f.toLowerCase().endsWith('.jpg'))
    .sort()
    .map((f) => ({
      value: `/images/plans/${f}`,
      url: `${BASE}/images/plans/${f}`,
    }));
}
---

<section class="adm-panel" data-panel="plan" hidden>
  <header class="adm-panel__head">
    <h2 class="adm-panel__title">プラン管理
    <span id="plan-count" class="adm-count"></span>
    <div class="adm-toolbar">
      <button type="button" id="plan-add-btn" class="adm-btn adm-btn--primary">＋ 新規プランを追加</button>
      <button type="button" id="plan-export-btn" class="adm-btn adm-btn--export">Firestore に保存</button>
    </div>

    </h2>
    <p class="adm-lead">
      ブライダルプランの管理ページ
    </p>
    <p id="plan-status" class="adm-status"></p>
  </header>

  <div id="plan-editor"></div>

  <!-- 画像ピッカー（パネルに1つだけ。各カードの「画像を選ぶ」から共用する） -->
  <div id="plan-picker" class="adm-picker" hidden>
    <div class="adm-picker__backdrop" data-picker-close></div>
    <div class="adm-picker__panel" role="dialog" aria-modal="true" aria-label="画像を選択">
      <div class="adm-picker__head">
        <h3 class="adm-picker__title">画像を選ぶ（プラン）</h3>
        <button type="button" class="adm-btn adm-btn--mini" data-picker-close>閉じる</button>
      </div>
      <div id="plan-picker-grid" class="adm-picker__grid"></div>
    </div>
  </div>

  <!-- ビルド時に public/images/plans/ から作った画像一覧（value=保存値 / url=表示用） -->
  <script type="application/json" id="plan-image-list" is:inline set:html={JSON.stringify(planImages)}></script>
</section>

<script>
  import type { Plan, Taxonomy } from '../../types';
  import { countLabel, makeDocId } from '../../lib/admin';
  // getTaxonomiesFromDb を追加：チェックボックスの選択肢（plan-includes / plan-tags マスター）を読む
  import { getPlansFromDb, savePlanToDb, deletePlanFromDb, getTaxonomiesFromDb } from '../../lib/firestore';
  import { auth } from '../../lib/firebase';
  import { onAuthStateChanged } from 'firebase/auth';
  import Sortable from 'sortablejs'; // 並べ替え（ドラッグ＆ドロップ）。管理画面でのみ読み込む

  // 画像未選択時の既定サムネイル（公開サイトにもこの画像が出る）
  const NO_IMAGE = '/images/noimage.jpg';

  const init = (): void => {
    const container = document.querySelector<HTMLElement>('#plan-editor');
    const addBtn = document.querySelector<HTMLButtonElement>('#plan-add-btn');
    const exportBtn = document.querySelector<HTMLButtonElement>('#plan-export-btn');
    const statusEl = document.querySelector<HTMLElement>('#plan-status');
    if (!container || !addBtn || !exportBtn || !statusEl) return;

    let working: Plan[] = [];
    let savedIds = new Set<string>();
    // 公開状態の「最後に読み込み／保存した時点」のスナップショット（id→公開中か）。
    // 保存時に「表示↔非表示が変わったプラン」を洗い出して確認ポップアップを出すために使う。
    let savedPub = new Map<string, boolean>();

    // 「最後に読み込み／保存した時点」の各プランの中身スナップショット（id→{内容文字列, タイトル}）。
    // 今の working と見比べて「変更されたプラン」を特定するために使う。
    let savedSnap = new Map<string, { content: string; title: string }>();
    // 同じく、保存／読み込み時点の並び順（id を連結した文字列）。表示順だけ変わった検知に使う。
    let savedOrderSig = '';

    // 「含まれるもの」の選択肢（マスター plan-includes）。load() で取得し、描画と取り込みで参照する。
    let includeChoices: Taxonomy[] = [];
    // 「対象スタイル」の選択肢（マスター plan-tags）。includeChoices と同じ使い方。
    let tagChoices: Taxonomy[] = [];
    // 並べ替え用 Sortable インスタンス。再描画のたびに作り直す（破棄→生成）。
    let sortable: Sortable | null = null;

    // ---- 画面の状態 ----
    let view: 'list' | 'edit' = 'list'; // いま一覧か編集か
    let editingIndex = -1;              // 編集中プランの working 内の位置（一覧時は -1）
    let reorderMode = false;            // 並べ替えモードON/OFF（一覧ビューでのみ意味を持つ）

    // ---- セレクタ生成（data-* 属性で要素を一意に指す）----
    // プランは日程を持たないので、フェアの daySel / slotSel は不要。fieldSel だけ。
    const fieldSel = (pi: number, field: string): string =>
      `[data-pi="${pi}"][data-field="${field}"]`;

    // ---- 値の読み取り（DOM → 値）----
    const valOf = (sel: string): string => {
      const el = container.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(sel);
      return el ? el.value.trim() : '';
    };
    const rawValOf = (sel: string): string => {
      // textarea の改行を保つため trim しない読み取り
      const el = container.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(sel);
      return el ? el.value : '';
    };
    const checkedOf = (sel: string): boolean => {
      const el = container.querySelector<HTMLInputElement>(sel);
      return el ? el.checked : false;
    };

    // ---- 値の書き込み（値 → DOM）----
    const setVal = (sel: string, v: string): void => {
      const el = container.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(sel);
      if (el) el.value = v;
    };
    const setChecked = (sel: string, v: boolean): void => {
      const el = container.querySelector<HTMLInputElement>(sel);
      if (el) el.checked = v;
    };

    // 文字列を HTML に安全に埋め込む（一覧のタイトル等。'<' などを実体参照に変換）
    const escapeHtml = (s: string): string =>
      s.replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] ?? c)
      );

    // 保存値(base無し /images/...) → 画面表示URL(base付き)。frontmatter の BASE とは別スコープ
    const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
    const toUrl = (src: string): string => (src ? `${BASE}${src}` : '');
    // サムネ欄のプレビュー画像を更新（空なら src を外して隠す）
    const setThumbPreview = (pi: number, src: string, alt: string): void => {
      const img = container.querySelector<HTMLImageElement>(`[data-pi="${pi}"][data-thumb-preview]`);
      if (!img) return;
      if (src) {
        img.src = toUrl(src);
        img.hidden = false;
      } else {
        img.removeAttribute('src');
        img.hidden = true;
      }
      img.alt = alt ?? '';
    };

    // ---- ファイル名 / フルパスのヘルパー ----
    const fileNameOf = (src: string): string => src.split('/').pop() ?? '';
    const setThumbField = (pi: number, fullPath: string): void => {
      const input = container.querySelector<HTMLInputElement>(fieldSel(pi, 'thumbnailSrc'));
      if (input) {
        input.value = fileNameOf(fullPath); // 画面にはファイル名だけ
        input.dataset.fullpath = fullPath;  // 保存用のフルパスは data 属性に隠す
      }
      setThumbPreview(pi, fullPath, '');
    };
    const fullPathOf = (pi: number): string => {
      const input = container.querySelector<HTMLInputElement>(fieldSel(pi, 'thumbnailSrc'));
      return input?.dataset.fullpath ?? '';
    };

    // ---- 数値項目の取り込みヘルパー ----
    // 空文字や数値でない入力は「未設定（undefined）」として扱う。任意の数値項目（priceTo / guestCountBase / sortOrder）用。
    const numOrUndef = (sel: string): number | undefined => {
      const s = valOf(sel);
      const n = Number(s);
      return s === '' || Number.isNaN(n) ? undefined : n;
    };

    // オブジェクトのキー順に依存せず比較できるよう、キーを再帰的にソートして JSON 化する。
    // （harvest がプロパティを入れ直すとキー順が変わり得るため、素の JSON.stringify では誤検知する）
    const sortedJson = (obj: unknown): string => {
      const sortKeys = (x: unknown): unknown => {
        if (Array.isArray(x)) return x.map(sortKeys);
        if (x !== null && typeof x === 'object') {
          const o = x as Record<string, unknown>;
          const out: Record<string, unknown> = {};
          for (const k of Object.keys(o).sort()) out[k] = sortKeys(o[k]);
          return out;
        }
        return x;
      };
      return JSON.stringify(sortKeys(obj));
    };

    // 比較用の「中身」文字列。sortOrder（並び順）は別枠で見るので除外、alt はタイトルからの自動派生なので除外。
    // ＝こうしないと「開いただけ」「並べ替えただけ」で中身が変わったと誤検知してしまう。
    const contentOf = (p: Plan): string => {
      const { sortOrder, thumbnail, ...rest } = p;
      void sortOrder;
      return sortedJson({ ...rest, thumbnail: { src: thumbnail.src } });
    };

    // 今の working を「保存済み」として記録する（読み込み後・保存成功後に呼ぶ）。
    const snapshotSaved = (): void => {
      savedSnap = new Map(
        working.map((p): [string, { content: string; title: string }] => [
          p.id,
          { content: contentOf(p), title: p.title },
        ])
      );
      savedOrderSig = working.map((p) => p.id).join(',');
    };

    // 未保存のプランのラベル一覧を返す（修正／新規作成／削除／並び替え）。空配列なら未保存なし。
    // 「切り替わる瞬間」の通知＝index.astro のタブ切り替え確認・beforeunload から共通で使う。
    const unsavedLabels = (): string[] => {
      harvest(); // 編集中の1件を working に反映してから比べる（入力途中も取りこぼさない）
      const labels: string[] = [];
      const currentIds = new Set(working.map((p) => p.id));
      working.forEach((p) => {
        const snap = savedSnap.get(p.id);
        if (!snap) labels.push(`【新規作成】${p.title || '（無題）'}`);
        else if (snap.content !== contentOf(p)) labels.push(`【修正】${p.title || '（無題）'}`);
      });
      savedSnap.forEach((snap, id) => {
        if (!currentIds.has(id)) labels.push(`【削除】${snap.title || id}`);
      });
      // 追加も削除もない（メンバーが同じ）のに並び順だけ変わったら、並び替えとして1行
      const sameMembers =
        currentIds.size === savedSnap.size && [...currentIds].every((id) => savedSnap.has(id));
      if (sameMembers && working.map((p) => p.id).join(',') !== savedOrderSig) {
        labels.push('【並び替え】');
      }
      return labels;
    };

    // 未保存があれば status 欄に内容を出す。無ければ status を空にする。
    // 「一覧に戻る瞬間」「並べ替えモード終了時」だけ呼ぶ（入力のたびには呼ばない＝編集中は静かなまま）。
    const noticeUnsaved = (): void => {
      const labels = unsavedLabels();
      if (labels.length === 0) {
        setStatus('', '');
        return;
      }
      setStatus('未保存の内容があります。\n' + labels.join('\n'), 'warn');
    };

    // ---- 手動サンプルの欠損補完 ----
    // 必須の文字列/オブジェクト/数値を安全な初期値で補う（画面に "undefined" を出さないため）。
    const normalizePlan = (p: Plan): Plan => {
      // 旧フィールド includes（自由入力時代の文字列配列）／styleIds（plan-tags 化前）が
      // Firestore に残っていても引きずらないよう取り除く（今は includeIds / tagIds に一本化）。
      const base = { ...p } as Plan & { includes?: string[]; styleIds?: string[] };
      delete base.includes;
      delete base.styleIds;
      return {
        ...base,
        title: base.title ?? '',
        description: base.description ?? '',
        thumbnail: {
          src: base.thumbnail?.src || NO_IMAGE, // 空・未設定なら noimage を既定に
          alt: base.thumbnail?.alt ?? '',
        },
        priceFrom: base.priceFrom ?? 0, // 必須(number)。欠けると価格表示や型が壊れるので 0 で補完
        isPublished: base.isPublished ?? false,
      };
    };

    // ---- 画面 → working（1件分）----
    const harvestPlan = (plan: Plan, pi: number): void => {
      plan.id = valOf(fieldSel(pi, 'id'));
      plan.title = valOf(fieldSel(pi, 'title'));
      plan.description = rawValOf(fieldSel(pi, 'description')).trim();
      plan.thumbnail = {
        src: fullPathOf(pi) || NO_IMAGE, // .value はファイル名なので data-fullpath を読む
        alt: plan.title,                 // alt はタイトルを自動採用
      };

      // priceFrom は必須（number）。空や不正値のときは 0 を入れておき、書き出し前チェックで警告する。
      const pf = valOf(fieldSel(pi, 'priceFrom'));
      const pfNum = Number(pf);
      plan.priceFrom = pf === '' || Number.isNaN(pfNum) ? 0 : pfNum;

      // priceTo / guestCountBase は任意。未入力なら undefined（JSONに出さない）。
      plan.priceTo = numOrUndef(fieldSel(pi, 'priceTo'));
      plan.guestCountBase = numOrUndef(fieldSel(pi, 'guestCountBase'));

      // sortOrder（任意・数値）。並べ替えで管理するが、値の往復は hidden input 経由で行う。
      plan.sortOrder = numOrUndef(fieldSel(pi, 'sortOrder'));

      // セレクトの値（published/hidden）を真偽に変換。'published' のときだけ true。
      plan.isPublished = valOf(fieldSel(pi, 'isPublished')) === 'published';

      // 含まれるもの：マスター由来のチェックボックスから、チェックされた id を集める。空配列なら undefined。
      const includeIds = includeChoices
        .map((c) => c.id)
        .filter((id) => checkedOf(fieldSel(pi, 'includeIds') + `[data-include-id="${id}"]`));
      plan.includeIds = includeIds.length ? includeIds : undefined;
      // 対象スタイル：同上。空配列なら undefined。
      const tagIds = tagChoices
        .map((c) => c.id)
        .filter((id) => checkedOf(fieldSel(pi, 'tagIds') + `[data-tag-id="${id}"]`));
      plan.tagIds = tagIds.length ? tagIds : undefined;
    };
    // 編集中の1件だけを working に退避する（一覧・並べ替え時はカードが無いので何もしない）
    const harvest = (): void => {
      if (view !== 'edit' || editingIndex < 0) return;
      const plan = working[editingIndex];
      if (plan) harvestPlan(plan, editingIndex);
    };

    // ---- working → 画面（1件分）----
    const populatePlan = (plan: Plan, pi: number): void => {
      setVal(fieldSel(pi, 'id'), plan.id);
      setVal(fieldSel(pi, 'title'), plan.title);
      setVal(fieldSel(pi, 'description'), plan.description);
      setThumbField(pi, plan.thumbnail.src); // 表示=ファイル名/保存=フルパス/プレビュー更新
      setVal(fieldSel(pi, 'priceFrom'), String(plan.priceFrom));
      setVal(fieldSel(pi, 'priceTo'), plan.priceTo === undefined ? '' : String(plan.priceTo));
      setVal(fieldSel(pi, 'guestCountBase'), plan.guestCountBase === undefined ? '' : String(plan.guestCountBase));
      setVal(fieldSel(pi, 'sortOrder'), plan.sortOrder === undefined ? '' : String(plan.sortOrder));
      // 真偽 → セレクトの値（published/hidden）。false は「非表示」。
      setVal(fieldSel(pi, 'isPublished'), plan.isPublished ? 'published' : 'hidden');
      // 含まれるもの：plan.includeIds に入っている id のチェックを入れる。
      const checkedInc = new Set(plan.includeIds ?? []);
      includeChoices.forEach((c) => {
        setChecked(fieldSel(pi, 'includeIds') + `[data-include-id="${c.id}"]`, checkedInc.has(c.id));
      });
      // 対象スタイル：plan.tagIds に入っている id のチェックを入れる。
      const checkedTag = new Set(plan.tagIds ?? []);
      tagChoices.forEach((c) => {
        setChecked(fieldSel(pi, 'tagIds') + `[data-tag-id="${c.id}"]`, checkedTag.has(c.id));
      });
    };
    // 編集中の1件だけを画面に流し込む
    const populateOne = (pi: number): void => {
      const plan = working[pi];
      if (plan) populatePlan(plan, pi);
    };

    // ---- HTML 組み立て（値は入れず、構造と data-* だけを作る）----
    // フェアと違い日程ブロックが無いので、1プラン=1カードのシンプルな構造。
    const planCard = (_plan: Plan, pi: number): string => {
      return `
      <section class="adm-card">
        <div class="adm-card__head">
          <h2>No. ${pi + 1}</h2>
          <label class="adm-title"><span class="adm-title__title">プランタイトル</span>
            <input type="text" data-pi="${pi}" data-field="title" placeholder="（タイトル）"/>
          </label>
          <label class="adm-pub"><span class="adm-pub__title">公開状態</span>
            <select data-pi="${pi}" data-field="isPublished">
              <option value="hidden">非表示</option>
              <option value="published">表示</option>
            </select>
          </label>
        </div>
        <label class="adm-id"><span class="adm-id__title">ID（自動発番・編集不可）</span>
          <input type="text" data-pi="${pi}" data-field="id" readonly />
        </label>

        <div class="adm-card__body">
          <div class="adm-row">
            <div class="adm-card__first">
              <label class="adm-field"><span class="adm-field-title">説明文</span>
                <textarea rows="3" data-pi="${pi}" data-field="description"></textarea>
              </label>
              <div class="adm-row">
                <label class="adm-field adm-field--narrow"><span class="adm-field-title">最低価格（円・必須）</span>
                  <input type="number" data-pi="${pi}" data-field="priceFrom" placeholder="1920000" />
                </label>
                <label class="adm-field adm-field--narrow"><span class="adm-field-title">上限価格（円・任意）</span>
                  <input type="number" data-pi="${pi}" data-field="priceTo" placeholder="3000000" />
                </label>
                <label class="adm-field adm-field--narrow"><span class="adm-field-title">基準人数（任意）</span>
                  <input type="number" data-pi="${pi}" data-field="guestCountBase" placeholder="100" />
                </label>
              </div>
              <!-- 表示順は「並べ替え」で管理するので画面には出さない。
                   ただし値の往復（populate→harvest）に input は必要なので hidden で残す。 -->
              <input type="hidden" data-pi="${pi}" data-field="sortOrder" />
              <p class="adm-hint">価格は総額（円）。上限価格を入れると「価格帯」、空なら単価として表示されます（詳細ページの出し分け）。</p>
            </div>

            <div class="adm-card__second">
              <label class="adm-field">
                <span class="adm-field-title">サムネイル画像</span>
              </label>
              <div class="adm-thumb">
                <img class="adm-thumb__preview" data-pi="${pi}" data-thumb-preview alt="" hidden />
                <div class="adm-row">
                  <input type="text" data-pi="${pi}" data-field="thumbnailSrc" readonly placeholder="（「画像を選ぶ」から選択）" />
                  <button type="button" class="adm-btn adm-btn--mini" data-action="pick-thumb" data-pi="${pi}">画像を選ぶ</button>
                </div>
              </div>
            </div>
          </div>

          <div class="adm-row">
            <div class="adm-field"><span class="adm-field-title">含まれるもの（「タグ／カテゴリー管理」のマスターから選択・複数可）</span>
              <div class="adm-radios">
                ${
                  includeChoices.length
                    ? includeChoices
                        .map(
                          (c) => `
                <label class="adm-radio"><input type="checkbox" data-pi="${pi}" data-field="includeIds" data-include-id="${c.id}" /> ${c.label}</label>`,
                        )
                        .join('')
                    : '<p class="adm-hint">選択肢がまだありません。「タグ／カテゴリー管理」タブの「プランに含まれるもの」で追加してください。</p>'
                }
              </div>
            </div>
          </div>
          <div class="adm-row">
            <div class="adm-field"><span class="adm-field-title">対象スタイル（「タグ／カテゴリー管理」のマスターから選択・複数可）</span>
              <div class="adm-radios">
                ${
                  tagChoices.length
                    ? tagChoices
                        .map(
                          (c) => `
                <label class="adm-radio"><input type="checkbox" data-pi="${pi}" data-field="tagIds" data-tag-id="${c.id}" /> ${c.label}</label>`,
                        )
                        .join('')
                    : '<p class="adm-hint">選択肢がまだありません。「タグ／カテゴリー管理」タブの「プランの対象スタイル」で追加してください。</p>'
                }
              </div>
            </div>
          </div>
          <button type="button" class="adm-btn adm-btn--danger" data-action="del-plan" data-pi="${pi}">プラン削除</button>
        </div>
      </section>`;
    };

    // ---- 一覧ビュー用：表示テキストを組み立てるヘルパー ----

    // id 配列 → ラベル配列。マスター（choices）に無い id は捨てる（公開側と同じ「未知idはスキップ」）。
    const labelsOf = (ids: string[] | undefined, choices: Taxonomy[]): string[] => {
      if (!ids || ids.length === 0) return [];
      return ids
        .map((id) => choices.find((c) => c.id === id)?.label)
        .filter((label): label is string => !!label);
    };

    // 金額を「1,920,000円」に整形。priceFrom が 0 以下のときは未設定扱い。
    const yen = (n: number): string => `${n.toLocaleString('ja-JP')}円`;
    const priceTextOf = (plan: Plan): string => {
      if (plan.priceFrom <= 0) return '未設定';
      return plan.priceTo !== undefined
        ? `${yen(plan.priceFrom)}〜${yen(plan.priceTo)}` // 上限あり＝価格帯
        : yen(plan.priceFrom);                          // 上限なし＝単価
    };

    // ---- 一覧ビューの行（クリックで編集へ。data-field を持たせない＝harvest に拾われない）----
    // 左にサムネ、右にタイトル＋公開バッジ＋価格／含まれるもの／対象スタイル を縦に積む。
    // CSSは fair-list* を流用（フェアと同じ見た目・admin.css 無改修）。
    const planListItem = (plan: Plan, pi: number): string => {
      const thumbUrl = toUrl(plan.thumbnail.src);                                  // base 付きの表示用URL
      const priceText = priceTextOf(plan);                                         // 価格（単価 or 価格帯）
      const includesText = labelsOf(plan.includeIds, includeChoices).join('、') || '未設定'; // 含まれるもの
      const tagsText = labelsOf(plan.tagIds, tagChoices).join('、') || '未設定';            // 対象スタイル
      return `
      <li class="fair-list__row">
        <button type="button" class="fair-list__btn" data-action="edit-plan" data-pi="${pi}">
          <span class="fair-list__thumb">
            <img src="${escapeHtml(thumbUrl)}" alt="${escapeHtml(plan.title)}" loading="lazy" />
          </span>
          <span class="fair-list__main">
            <span class="fair-list__titlerow">
              <span class="fair-list__no">No. ${pi + 1}</span>
              <span class="fair-list__title">${escapeHtml(plan.title) || '（無題）'}</span>
              <span class="fair-list__badge ${plan.isPublished ? 'is-pub' : 'is-unpub'}">${plan.isPublished ? '表示' : '非表示'}</span>
            </span>
            <span class="fair-list__meta"><span class="fair-list__key">価格</span>${escapeHtml(priceText)}</span>
            <span class="fair-list__meta"><span class="fair-list__key">含まれるもの</span>${escapeHtml(includesText)}</span>
            <span class="fair-list__meta"><span class="fair-list__key">対象スタイル</span>${escapeHtml(tagsText)}</span>
          </span>
        </button>
      </li>`;
    };

    // ---- 並べ替えモードの行（ドラッグ専用。クリックで編集に飛ばない＝<button>にしない）----
    const reorderItem = (plan: Plan, pi: number): string => `
      <li class="fair-reorder__item" data-reorder-index="${pi}">
        <span class="fair-reorder__handle" aria-hidden="true">≡</span>
        <span class="fair-reorder__no">No. ${pi + 1}</span>
        <span class="fair-reorder__title">${escapeHtml(plan.title) || '（無題）'}</span>
      </li>`;

    // ---- 一覧ビュー全体（通常 or 並べ替えモード）----
    // ※ 並べ替えリストの id は #plan-reorder-list（フェアの #fair-reorder-list と区別する）。
    const listViewHtml = (): string => {
      if (reorderMode) {
        const items = working.map((p, i) => reorderItem(p, i)).join('');
        return `
        <div class="fair-list">
          <div class="fair-list__bar">
            <button type="button" class="adm-btn" data-action="toggle-reorder">並べ替えを終了</button>
            <span class="adm-hint">≡ をドラッグして表示順を入れ替え。終わったら「Firestore に保存」で確定します。</span>
          </div>
          <ul class="fair-reorder__list" id="plan-reorder-list">${items}</ul>
        </div>`;
      }
      const items = working.map((p, i) => planListItem(p, i)).join('');
      const empty =
        working.length === 0
          ? `<p class="adm-hint">プランがありません。「＋ 新規プランを追加」から作成してください。</p>`
          : '';
      return `
      <div class="fair-list">
        <div class="fair-list__bar">
          <button type="button" class="adm-btn" data-action="toggle-reorder">並べ替える</button>
        </div>
        <ul class="fair-list__items">${items}</ul>
        ${empty}
      </div>`;
    };

    // ---- 編集ビュー全体（1件のカード＋戻るボタン）----
    const editViewHtml = (pi: number): string => `
      <div class="fair-edit">
        <div class="fair-edit__bar">
          <button type="button" class="adm-btn" data-action="back-to-list">← 一覧に戻る</button>
        </div>
        ${planCard(working[pi]!, pi)}
      </div>`;

    // 並べ替え一覧に Sortable を初期化（並べ替えモードのときだけ呼ぶ）。
    const initSortable = (): void => {
      const listEl = container.querySelector<HTMLElement>('#plan-reorder-list');
      if (!listEl) return;
      sortable?.destroy(); // 古いインスタンスを破棄（DOM を作り直すので二重登録を防ぐ）
      sortable = Sortable.create(listEl, {
        handle: '.fair-reorder__handle', // ハンドル（≡）部分だけドラッグ可能にする
        animation: 150,
        onEnd: (evt) => {
          const from = evt.oldIndex;
          const to = evt.newIndex;
          if (from === undefined || to === undefined || from === to) return;
          const moved = working.splice(from, 1)[0]; // 動かした1件を抜き出す
          if (!moved) return;
          working.splice(to, 0, moved); // 新しい位置に挿し込む
          working.forEach((p, i) => {
            p.sortOrder = i; // 上から 0,1,2… に振り直す
          });
          render(); // 一覧を新しい順で描き直す（Sortable も貼り直される）
        },
      });
    };

    // ---- 描画（state を見て一覧/編集を出し分ける）----
    const render = (): void => {
      sortable?.destroy(); // どのビューでも一旦破棄。並べ替えモードのときだけ後で貼り直す
      sortable = null;

      if (view === 'edit' && editingIndex >= 0 && working[editingIndex]) {
        container.innerHTML = editViewHtml(editingIndex);
        populateOne(editingIndex); // 1件分だけ値を流し込む
      } else {
        // 編集対象が無ければ一覧に戻す（安全側）
        view = 'list';
        editingIndex = -1;
        container.innerHTML = listViewHtml();
        if (reorderMode) initSortable();
      }

      addBtn.hidden = view === 'edit'; // 編集中は「＋新規追加」を隠す（一覧でのみ追加）
      const countEl = document.querySelector<HTMLSpanElement>('#plan-count');
      if (countEl) countEl.textContent = countLabel(working);
    };

    // ステータス表示
    const setStatus = (msg: string, kind: 'ok' | 'warn' | ''): void => {
      statusEl.textContent = msg;
      statusEl.className = 'adm-status' + (kind ? ' is-' + kind : '');
    };

    // 新規プランのひな型（必須項目だけ）。priceFrom は number 必須なので 0 で初期化。
    // id は makeDocId('p') で自動発番（新規作成時のみ）。'p' はプラン用の接頭辞（フェアは 'f'）。
    const blankPlan = (): Plan => ({
      id: makeDocId('p'),
      title: '',
      description: '',
      thumbnail: { src: NO_IMAGE, alt: '' },
      priceFrom: 0,
      isPublished: false,
    });

    // 書き出し前の簡易チェック（ビルドを壊しやすい・表示が崩れやすい項目だけ）
    const validate = (): string[] => {
      const errs: string[] = [];
      const seen = new Set<string>();
      working.forEach((plan, i) => {
        // 一覧では1件ずつしか見えないので、どのプランの問題か分かるよう「No.＋タイトル」で示す
        const label = `No.${i + 1}${plan.title ? `「${plan.title}」` : '（無題）'}`;
        if (plan.id === '') errs.push(`${label}: ID が空です`);
        else if (seen.has(plan.id)) errs.push(`${label}: ID「${plan.id}」が重複しています`);
        seen.add(plan.id);
        if (plan.title === '') errs.push(`${label}: タイトルが空です`);
        if (plan.thumbnail.src === '') errs.push(`${label}: サムネイル画像が未選択です`);
        if (plan.priceFrom <= 0) errs.push(`${label}: 最低価格が未入力（または0）です`);
        if (plan.priceTo !== undefined && plan.priceTo < plan.priceFrom)
          errs.push(`${label}: 上限価格が最低価格より小さくなっています`);
      });
      return errs;
    };

    // ---- 画像ピッカー（サムネ専用・1枚選択）----
    const picker = document.querySelector<HTMLElement>('#plan-picker');
    const pickerGrid = document.querySelector<HTMLElement>('#plan-picker-grid');
    let pickerTargetPi = -1; // いま選択対象のカード番号（pi）

    // ビルド時に埋め込んだ画像一覧（value=保存値 / url=表示用）を読む
    const imageListEl = document.querySelector<HTMLScriptElement>('#plan-image-list');
    const imageList: { value: string; url: string }[] =
      imageListEl ? JSON.parse(imageListEl.textContent ?? '[]') : [];

    // グリッドは中身が固定なので一度だけ組み立てる
    if (pickerGrid) {
      pickerGrid.innerHTML = imageList
        .map(
          (img) => `
        <button type="button" class="adm-picker__item" data-pick-value="${img.value}">
          <img src="${img.url}" alt="" loading="lazy" />
          <span class="adm-picker__name">${img.value.split('/').pop() ?? ''}</span>
        </button>`
        )
        .join('');
    }

    const openPicker = (pi: number): void => {
      if (picker) {
        pickerTargetPi = pi;
        picker.hidden = false;
      }
    };
    const closePicker = (): void => {
      if (picker) {
        picker.hidden = true;
        pickerTargetPi = -1;
      }
    };

    // サムネクリック → 対象カードの src 欄へ値を入れ、プレビュー更新 → 閉じる
    if (pickerGrid) {
      pickerGrid.addEventListener('click', (ev) => {
        const el = ev.target;
        if (!(el instanceof Element)) return;
        const item = el.closest<HTMLButtonElement>('button[data-pick-value]');
        if (!item || pickerTargetPi < 0) return;
        const value = item.dataset.pickValue ?? '';
        setThumbField(pickerTargetPi, value); // 表示=ファイル名/保存=フルパス/プレビュー
        closePicker();
      });
    }

    // 背景クリック・「閉じる」ボタンで閉じる
    if (picker) {
      picker.addEventListener('click', (ev) => {
        const el = ev.target;
        if (el instanceof Element && el.closest('[data-picker-close]')) closePicker();
      });
    }

    // index.astro のタブ切り替えから「未保存のプラン一覧」を読めるよう、関数を window に登録する。
    // 各パネルが自分の data-panel 名で1つずつ登録する想定（フェアは .fair、ここは .plan）。
    const w = window as unknown as { adminDirtyReporters?: Record<string, () => string[]> };
    w.adminDirtyReporters = w.adminDirtyReporters ?? {};
    w.adminDirtyReporters.plan = unsavedLabels;

    // ページ離脱（閉じる・再読み込み・別URLへ移動）時、未保存があればブラウザ標準の警告を出す。
    // ※文言はブラウザ仕様で固定（カスタム不可）。タブ切り替えは同一ページ内なので
    //   ここでは出ない→index.astro 側で unsavedLabels() を呼んで一覧付きの確認を出す。
    window.addEventListener('beforeunload', (e) => {
      if (unsavedLabels().length === 0) return;
      e.preventDefault();
    });

    // ---- イベント（構造変更・ナビゲーションはイベント委譲でまとめて受ける）----
    container.addEventListener('click', (ev) => {
      const el = ev.target;
      if (!(el instanceof Element)) return;
      const btn = el.closest<HTMLButtonElement>('button[data-action]');
      if (!btn) return;
      const action = btn.dataset.action ?? '';
      const pi = btn.dataset.pi !== undefined ? Number(btn.dataset.pi) : -1;

      // 画像ピッカーを開く（harvest 不要）
      if (action === 'pick-thumb') {
        openPicker(pi);
        return;
      }

      // ---- ナビゲーション系 ----
      if (action === 'edit-plan') {
        if (pi >= 0) {
          view = 'edit';
          editingIndex = pi;
          render();
        }
        return;
      }
      if (action === 'back-to-list') {
        harvest(); // 編集中の内容を working に退避してから戻る（変更は保持される）
        view = 'list';
        editingIndex = -1;
        render();
        noticeUnsaved(); // 一覧に戻る瞬間だけ、未保存があれば status に表示
        return;
      }
      if (action === 'toggle-reorder') {
        reorderMode = !reorderMode;
        render();
        if (reorderMode) setStatus('並べ替えモードです。≡ をドラッグしてください。', '');
        else noticeUnsaved(); // 並べ替えモードを抜けた瞬間、未保存があれば status に表示
        return;
      }

      // ---- 編集ビュー内のカード操作（削除）----
      harvest();
      if (action === 'del-plan') {
        if (pi >= 0 && window.confirm('このプランを削除します。よろしいですか？')) {
          working.splice(pi, 1);
          view = 'list'; // 削除したら一覧へ戻る
          editingIndex = -1;
        }
      }
      render();
    });

    addBtn.addEventListener('click', () => {
      harvest(); // 編集中があれば退避（一覧なら何もしない）
      working.push(blankPlan());
      view = 'edit';
      editingIndex = working.length - 1; // 追加した新規プランをそのまま編集ビューで開く
      render();
    });

    exportBtn.addEventListener('click', async () => {
      harvest(); // 編集中の1件を最新化（一覧/並べ替え時は何もしない）

      const errs = validate();
      if (errs.length > 0) {
        const ok = window.confirm('入力に確認ポイントがあります。それでも保存しますか？\n\n' + errs.join('\n'));
        if (!ok) {
          setStatus('保存を中止しました。', 'warn');
          return;
        }
      }

      // 公開状態（表示↔非表示）が変わるプランを洗い出して、まとめて確認する。
      const pubChanges = working
        .filter((p) => savedPub.has(p.id) && savedPub.get(p.id) !== p.isPublished)
        .map((p) => `${p.title || p.id}: ${p.isPublished ? '非表示 → 表示' : '表示 → 非表示'}`);
      if (pubChanges.length > 0) {
        const okPub = window.confirm(
          '公開状態が変わるプランがあります。保存してよいですか？\n\n' + pubChanges.join('\n')
        );
        if (!okPub) {
          setStatus('保存を中止しました。', 'warn');
          return;
        }
      }

      // 削除同期：読み込み時にあった id のうち、今 working に無い id を「削除対象」にする。
      const currentIds = new Set(working.map((p) => p.id));
      const toDelete = [...savedIds].filter((id) => !currentIds.has(id));

      if (toDelete.length > 0) {
        const okDel = window.confirm(
          `次の ${toDelete.length} 件を Firestore から削除します（元に戻せません）:\n` + toDelete.join('\n')
        );
        if (!okDel) {
          setStatus('保存を中止しました。', 'warn');
          return;
        }
      }

      exportBtn.disabled = true;
      const original = exportBtn.textContent ?? '';
      exportBtn.textContent = '保存中…';
      setStatus('Firestore に保存しています…', '');

      try {
        for (const id of toDelete) {
          await deletePlanFromDb(id);
        }
        for (const plan of working) {
          await savePlanToDb(plan);
        }
        savedIds = new Set(currentIds);
        savedPub = new Map(working.map((p): [string, boolean] => [p.id, p.isPublished])); // 公開状態スナップショット更新
        snapshotSaved(); // 中身・並び順のスナップショットも更新（＝未保存ゼロになる）
        setStatus(`保存しました（更新 ${working.length} 件 / 削除 ${toDelete.length} 件）。`, 'ok');
      } catch (e) {
        console.error('保存失敗:', e);
        setStatus('保存に失敗しました（ログイン状態・通信・ルールを確認してください）。', 'warn');
      } finally {
        exportBtn.disabled = false;
        exportBtn.textContent = original;
      }
    });

    // ---- Firestore からの読み込み（ログイン確定後だけ呼ぶ）----
    const load = async (): Promise<void> => {
      setStatus('読み込み中…', '');
      try {
        // プラン本体と、選択肢マスター（plan-includes / plan-tags）を同時に取得する。
        const [plans, taxonomies] = await Promise.all([getPlansFromDb(), getTaxonomiesFromDb()]);
        includeChoices = taxonomies
          .filter((t) => t.group === 'plan-includes' && t.isPublished)
          .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
        tagChoices = taxonomies
          .filter((t) => t.group === 'plan-tags' && t.isPublished)
          .sort((a, b) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
        working = plans.map(normalizePlan);
        savedIds = new Set(working.map((p) => p.id));
        savedPub = new Map(working.map((p): [string, boolean] => [p.id, p.isPublished])); // 公開状態スナップショット
        snapshotSaved(); // 中身・並び順のスナップショット（＝読み込み直後は未保存なし）
        // 読み込み直後は必ず一覧から（編集状態をリセット）
        view = 'list';
        editingIndex = -1;
        reorderMode = false;
        render();
        setStatus('', ''); // 読み込み直後は未保存なし＝status は空にする
      } catch (e) {
        console.error('読み込み失敗:', e);
        setStatus('読み込みに失敗しました（ログイン状態・通信を確認してください）。', 'warn');
      }
    };

    // ログイン状態が確定してから読み込む（ルールが auth != null のため、認証前に読むと permission-denied）。
    onAuthStateChanged(auth, (user) => {
      if (user) {
        load();
      } else {
        working = [];
        view = 'list';
        editingIndex = -1;
        reorderMode = false;
        savedPub = new Map();
        savedSnap = new Map();
        savedOrderSig = '';
        render();
      }
    });
  };

  init();
</script>