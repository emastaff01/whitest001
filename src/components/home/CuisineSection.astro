---
// =============================================================
// CuisineSection.astro  （TOPページ / CUISINEセクション）
// -------------------------------------------------------------
// ・料理紹介セクション。
// ・現時点では料理写真が手元に無いため、テキスト主体の静謐な構成にしている。
//   将来クライアントから料理写真が提供されたら、CHAPELやBANQUETと同じく
//   2カラム（画像＋テキスト）に拡張する想定。
// ・末尾に詳細ページ /cuisine/（後セッションで実装）への導線。
// ・文言は仮。上司・クライアント確認後に差し替えてください。
// =============================================================

import { url } from '../../lib/url';

// ---- 本文（仮・編集可）----
const overline = 'CUISINE';
const headline = '邸宅で仕上げる、季節のひと皿';
const bodyParagraphs = [
  '邸宅内の厨房で、ひと皿ずつ温度と時間を整え、最良の状態で席にお運びします。',
  '食材は地の産地から、季節のうつろいに沿って選びます。',
  'ご試食やお打ち合わせの段階から、お好みやアレルギーをぜひ共有させてください。',
];
---

<section class="cuisine" aria-labelledby="cuisine-heading">
  <div class="cuisine__inner">
    <p class="cuisine__overline">{overline}</p>
    <h2 id="cuisine-heading" class="cuisine__headline">{headline}</h2>
    <div class="cuisine__body">
      {/* set:html により <br /> 等のHTMLを文字列内に書ける */}
      {bodyParagraphs.map((p) => <p set:html={p} />)}
    </div>
    <p class="cuisine__more">
      <a href={url('/cuisine/')}>料理について見る</a>
    </p>
  </div>
</section>

<style>
  .cuisine {
    background-color: var(--off-white);
    padding-block: var(--space-section-y);
  }
  .cuisine__inner {
    max-width: var(--maxw-narrow);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
    text-align: center;
  }
  .cuisine__overline {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--green);
    margin-bottom: 28px;
  }
  .cuisine__headline {
    font-family: var(--font-jp-serif);
    font-weight: var(--weight-light);
    font-size: clamp(1.5rem, 3.2vw, 2.2rem);
    line-height: 1.5;
    color: var(--charcoal);
    margin-bottom: 48px;
  }
  .cuisine__body {
    font-family: var(--font-jp-sans);
    font-weight: var(--weight-regular);
    font-size: clamp(0.92rem, 1.6vw, 1rem);
    line-height: var(--lh-body);
    color: var(--dark-gray);
  }
  .cuisine__body p + p {
    margin-top: 1.4em;
  }
  .cuisine__more {
    margin-top: 56px;
  }
  .cuisine__more a {
    font-family: var(--font-jp-sans);
    font-size: 0.85rem;
    color: var(--green);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .cuisine__more a::after {
    content: '  →';
    color: var(--green);
  }
  .cuisine__more a:hover {
    color: var(--charcoal);
    border-bottom-color: var(--charcoal);
  }
  .cuisine__more a:hover::after {
    color: var(--charcoal);
  }
</style>
