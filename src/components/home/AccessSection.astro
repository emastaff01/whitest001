---
// =============================================================
// AccessSection.astro  （TOPページ / ACCESSセクション）
// -------------------------------------------------------------
// ・MEO（ローカルSEO）対策として、NAP情報（名称・住所・電話）を
//   構造化された <dl> で全ページ統一表記。
// ・Googleマップは API キー不要の埋め込みURL（query指定）で表示。
//   loading="lazy" にしてLCPに影響しないよう配慮。
// ・全情報は site-settings.json から取得しているので、変更があっても
//   1箇所の修正で全ページに反映される。
// =============================================================

import { getSiteSettings } from '../../lib/getSiteSettings';
import { url } from '../../lib/url';

const settings = getSiteSettings();
const nap = settings.nap;

// このセクションは TOP と /access の両方で使う共通部品。
// /access では上に PageHeader を別途置くため、見出しと「詳細を見る」自己リンクを隠せるようにする。
interface Props {
  showHeader?: boolean;     // 見出し(access__header)を出すか（未指定=true。TOPはtrueのまま）
  showDetailLink?: boolean; // 「アクセスの詳細を見る」リンクを出すか（未指定=true）
}
const { showHeader = true, showDetailLink = true } = Astro.props;

// Googleマップ埋め込み（APIキー不要のシンプルなクエリ埋め込み方式）
// 本番では Maps Embed API への移行も検討可（key 管理が必要）
const mapQuery = encodeURIComponent(`${nap.address} ${nap.name}`);
const mapEmbedUrl = `https://maps.google.com/maps?q=${mapQuery}&output=embed`;
const mapOpenUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;

// ---- セクション見出し ----
const overline = 'ACCESS';
const headline = '伊万里駅から徒歩10分、邸宅へ。';
---


<section
  class="access"
  aria-labelledby={showHeader ? 'access-heading' : undefined}
  aria-label={showHeader ? undefined : 'アクセス情報'}
>
  <div class="access__inner">
    
    {showHeader && (
      <header class="access__header">
        <p class="access__overline">{overline}</p>
        <h2 id="access-heading" class="access__headline">{headline}</h2>
      </header>
    )}

    <div class="access__grid">
      {/* 左カラム：NAP情報＋アクセス詳細 */}
      <div class="access__info">
        <dl class="access__dl">
          <div class="access__row">
            <dt>名称</dt>
            <dd>{nap.name}</dd>
          </div>
          <div class="access__row">
            <dt>住所</dt>
            <dd>
              〒{nap.postalCode}<br />
              {nap.address}
            </dd>
          </div>
          <div class="access__row">
            <dt>電話</dt>
            <dd>
              <a href={`tel:${nap.phone.replace(/-/g, '')}`} data-ga="phoneCV">
                {nap.phone}
              </a>
            </dd>
          </div>
          <div class="access__row">
            <dt>営業時間</dt>
            <dd>{settings.businessHours}</dd>
          </div>
          <div class="access__row">
            <dt>定休日</dt>
            <dd>{settings.closedDays}</dd>
          </div>
          <div class="access__row">
            <dt>アクセス</dt>
            <dd>{settings.access}</dd>
          </div>
          {
            settings.parking && (
              <div class="access__row">
                <dt>駐車場</dt>
                <dd>{settings.parking}</dd>
              </div>
            )
          }
        </dl>

        
        {showDetailLink && (
          <p class="access__more">
            <a href={url('/access/')}>アクセスの詳細を見る</a>
          </p>
        )}
      </div>

      {/* 右カラム：地図 */}
      <div class="access__map">
        <div class="access__map-frame">
          <iframe
            src={mapEmbedUrl}
            title={`${nap.name} 地図`}
            width="100%"
            height="100%"
            style="border:0;"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <p class="access__map-link">
          <a href={mapOpenUrl} target="_blank" rel="noopener noreferrer">
            Googleマップで開く
          </a>
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .access {
    background-color: var(--off-white);
    padding-block: var(--space-section-y);
  }
  .access__inner {
    max-width: var(--maxw-content);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
  }
  .access__header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }
  .access__overline {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--green);
    margin-bottom: 24px;
  }
  .access__headline {
    font-family: var(--font-jp-serif);
    font-weight: var(--weight-light);
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    line-height: 1.5;
    color: var(--charcoal);
  }

  .access__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 72px);
    align-items: start;
  }

  /* NAP情報 */
  .access__dl {
    font-family: var(--font-jp-sans);
    font-size: 0.92rem;
    line-height: var(--lh-body);
    color: var(--charcoal);
  }
  .access__row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    padding-block: 14px;
    border-bottom: 0.5px solid var(--hairline-dark);
  }
  .access__row:first-child {
    padding-top: 0;
  }
  .access__row dt {
    font-size: 0.78rem;
    color: var(--gray);
    letter-spacing: 0.04em;
    padding-top: 2px;
  }
  .access__row dd {
    color: var(--dark-gray);
  }
  .access__row dd a {
    color: var(--charcoal);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }
  .access__row dd a:hover {
    color: var(--green);
  }

  .access__more {
    margin-top: 32px;
  }
  .access__more a {
    font-family: var(--font-jp-sans);
    font-size: 0.85rem;
    color: var(--green);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .access__more a::after {
    content: '  →';
    color: var(--green);
  }
  .access__more a:hover {
    color: var(--charcoal);
    border-bottom-color: var(--charcoal);
  }
  .access__more a:hover::after {
    color: var(--charcoal);
  }

  /* 地図 */
  .access__map-frame {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: var(--pale-beige);
    overflow: hidden;
  }
  .access__map-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
  }
  .access__map-link {
    margin-top: 16px;
    text-align: right;
  }
  .access__map-link a {
    font-family: var(--font-jp-sans);
    font-size: 0.82rem;
    color: var(--green);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 2px;
  }
  .access__map-link a::after {
    content: '  ↗';
    color: var(--green);
  }
  .access__map-link a:hover {
    color: var(--charcoal);
    border-bottom-color: var(--charcoal);
  }

  @media (max-width: 768px) {
    .access__grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .access__row {
      grid-template-columns: 80px 1fr;
      gap: 12px;
    }
  }
</style>
