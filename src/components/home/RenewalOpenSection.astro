---
// =============================================================
// RenewalOpenSection.astro  （TOPページ / リブランドOPEN告知）
// -------------------------------------------------------------
// ・2026年6月の新装オープン告知。Hero・CONCEPTに次ぐ重要セクション。
// ・大きな英数字（Cormorant Garamond）で日付を視覚的に印象づけ、
//   本文で内容を補足、CTAで「ブライダルフェア」へ誘導する。
// ・日付は site-settings.json から取得（複数ページで使うため）。
// ・文言は仮。上司・クライアント確認後に差し替えてください。
// =============================================================

import { getSiteSettings } from '../../lib/getSiteSettings';
import CtaButton from '../common/CtaButton.astro';
import { url } from '../../lib/url';

const settings = getSiteSettings();
// 設定が無い場合のフォールバック（実運用ではsite-settings.jsonに必ず設定する）
const yearMonth = settings.renewalOpen?.displayYearMonth ?? '2026.06';
const textDate = settings.renewalOpen?.displayText ?? '2026年6月';

// ---- 本文（仮・編集可）----
const overline = 'RENEWAL OPEN';
const headline = `新しい邸宅として、${textDate}にOPEN`;
const bodyParagraphs = [
  'これまで大切にしてきた1棟貸切のおもてなしはそのままに、空間とサービスを一新します。',
  'オープン前のご見学・ご相談を順次お受けしています。',
];
---

<section class="renewal" aria-labelledby="renewal-heading">
  <div class="renewal__inner">
    <p class="renewal__date" aria-hidden="true">{yearMonth}</p>
    <p class="renewal__overline">{overline}</p>
    <h2 id="renewal-heading" class="renewal__headline">{headline}</h2>
    <div class="renewal__body reveal">
      {/* set:html により <br /> 等のHTMLを文字列内に書ける（ConceptSection と同じ理由）。 */}
      {bodyParagraphs.map((p) => <p set:html={p} />)}
    </div>
    <div class="renewal__cta">
      <CtaButton href={url('/fair/')} variant="solid" ga="fairCV">
        ブライダルフェアを見る
      </CtaButton>
    </div>
  </div>
</section>

<style>
  .renewal {
    background-color: var(--pale-beige);
    padding-block: var(--space-section-y);
  }
  .renewal__inner {
    max-width: var(--maxw-narrow);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
    text-align: center;
  }
  .renewal__date {
    font-family: var(--font-en-display);
    font-weight: var(--weight-light);
    font-size: clamp(3rem, 8vw, 5.5rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--green);
    margin-bottom: 24px;
  }
  .renewal__overline {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--dark-gray);
    margin-bottom: 28px;
  }
  .renewal__headline {
    font-family: var(--font-jp-serif);
    font-weight: var(--weight-light);
    font-size: clamp(1.35rem, 2.8vw, 1.9rem);
    line-height: 1.5;
    color: var(--charcoal);
    margin-bottom: 40px;
  }
  .renewal__body {
    font-family: var(--font-jp-sans);
    font-weight: var(--weight-regular);
    font-size: clamp(0.92rem, 1.6vw, 1rem);
    line-height: var(--lh-body);
    color: var(--dark-gray);
  }
  .renewal__body p + p {
    margin-top: 1.2em;
  }
  .renewal__cta{
    margin-top: 56px;
    display: flex;
    justify-content: center;
  }
  :global(.renewal__inner .renewal__cta a.cta) {
   width:230px;
   padding:.5rem;
  }
</style>
