---
// =============================================================
// PlanSection.astro  （TOPページ / PLANセクション）
// -------------------------------------------------------------
// ・getPlans() で plans.json から取得した公開プランを共通の PlanCard で表示。
//   将来 Firestore に差し替える場合は getPlans の中身だけ書き換えればOK。
// ・カード本体は ../plan/PlanCard.astro に切り出しているので、
//   /plan/ 一覧ページとデザインが完全に揃う（FairSection と同じ構成）。
// ・末尾に /plan/ 一覧ページへの導線。
// =============================================================

import { getPlans } from '../../lib/getPlans';
import { url } from '../../lib/url';
import PlanCard from '../plan/PlanCard.astro';

const plans = getPlans();

// ---- セクション見出し（仮・編集可）----
const overline = 'PLAN';
const headline = ['ふたりのスタイルにあわせて選ぶ<br>ブライダルプラン'];
const intro = '邸宅貸切から少人数まで、いくつかの基本プランをご用意しています。';
---

<section class="plan" aria-labelledby="plan-heading">
  <div class="plan__inner">
    <header class="plan__header">
      <p class="plan__overline">{overline}</p>
      <h2 id="plan-heading" class="plan__headline">{headline.map((p) => <p set:html={p} />)}</h2>
      <p class="plan__intro">{intro}</p>
    </header>

    <div class="plan__grid">
      {plans.map((plan) => <PlanCard plan={plan} />)}
    </div>

    <p class="plan__more">
      <a href={url('/plan/')}>プラン一覧へ</a>
    </p>
  </div>
</section>

<style>
  .plan {
    background-color: var(--white);
    padding-block: var(--space-section-y);
  }
  .plan__inner {
    max-width: var(--maxw-content);
    margin-inline: auto;
    padding-inline: var(--space-section-x);
  }
  .plan__header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }
  .plan__overline {
    font-family: var(--font-en-label);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--green);
    margin-bottom: 24px;
  }
  .plan__headline {
    font-family: var(--font-jp-serif);
    font-weight: var(--weight-light);
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    line-height: 1.5;
    color: var(--charcoal);
    margin-bottom: 20px;
  }
  .plan__intro {
    font-family: var(--font-jp-sans);
    font-size: clamp(0.88rem, 1.5vw, 0.95rem);
    line-height: var(--lh-body);
    color: var(--dark-gray);
  }

  .plan__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(24px, 3vw, 40px);
  }

  .plan__more {
    margin-top: clamp(48px, 6vw, 72px);
    text-align: center;
  }
  .plan__more a {
    font-family: var(--font-jp-sans);
    font-size: 0.9rem;
    color: var(--green);
    border-bottom: 0.5px solid var(--hairline-green);
    padding-bottom: 4px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .plan__more a::after {
    content: '  →';
    color: var(--green);
  }
  .plan__more a:hover {
    color: var(--charcoal);
    border-bottom-color: var(--charcoal);
  }
  .plan__more a:hover::after {
    color: var(--charcoal);
  }

  @media (max-width: 768px) {
    .plan__grid {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }
</style>
